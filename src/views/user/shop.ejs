<%- include('../layout/header') %>

<!-- SweetAlert2 (required for Add to Cart toasts) -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<main class="bg-white">

  <%/* ── Top Hero Banner ─────────────────────────────────────────── */%>
  <% if (locals.shopBanner) { %>
    <section class="relative w-full h-[250px] flex items-center justify-center overflow-hidden bg-cover bg-center"
             style="background-image: linear-gradient(rgba(255,255,255,0.7), rgba(255,255,255,0.7)), url('<%= shopBanner.imageUrl.startsWith('http') ? shopBanner.imageUrl : '/upload/banners/' + shopBanner.imageUrl %>');">
      <div class="text-center relative z-10">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-2"><%= shopBanner.title %></h1>
        <p class="text-sm font-semibold tracking-wider text-gray-600 uppercase">
          <a href="/" class="hover:text-[#B88E2F] transition-colors">Home</a>
          <span class="mx-2 text-gray-400">&gt;</span>
          <span class="text-[#B88E2F]">Shop</span>
        </p>
      </div>
    </section>
  <% } %>

  <%/* ── Controls Bar ────────────────────────────────────────────── */%>
  <section class="bg-[#FCF8F3] py-6 border-b border-gray-200">
    <div class="container mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-6">

      <%/* Search */%>
      <div class="w-full md:w-auto flex-grow max-w-lg">
        <form action="/shop" method="GET" class="flex items-center gap-2">
          <div class="relative w-full">
            <span class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-gray-400">
              <i class="fas fa-search"></i>
            </span>
            <input type="text" name="search" value="<%= searchQuery %>"
                   placeholder="Search product name or description..."
                   class="w-full border border-gray-300 rounded-lg pl-10 pr-10 py-2.5 text-sm focus:outline-none focus:border-[#B88E2F] focus:ring-1 focus:ring-[#B88E2F] bg-white text-gray-800">
            <% if (searchQuery) { %>
              <button type="button" onclick="clearSearch()"
                      class="absolute inset-y-0 right-0 pr-3 flex items-center text-gray-400 hover:text-gray-600">
                <i class="fas fa-times-circle"></i>
              </button>
            <% } %>
          </div>

          <%/* Preserve existing filters */%>
          <% if (selectedCategory) { %><input type="hidden" name="category" value="<%= selectedCategory %>"><% } %>
          <% if (minPrice) { %><input type="hidden" name="minPrice" value="<%= minPrice %>"><% } %>
          <% if (maxPrice) { %><input type="hidden" name="maxPrice" value="<%= maxPrice %>"><% } %>
          <% if (sortParam) { %><input type="hidden" name="sort" value="<%= sortParam %>"><% } %>

          <button type="submit"
                  class="bg-[#B88E2F] text-white px-6 py-2.5 rounded-lg text-sm font-bold hover:bg-[#967325] transition-all whitespace-nowrap shadow-sm">
            Search
          </button>
        </form>
      </div>

      <%/* Sort + Results info */%>
      <div class="w-full md:w-auto flex flex-wrap items-center justify-between md:justify-end gap-4">
        <span class="text-sm text-gray-600">
          Showing
          <span class="font-bold text-gray-900">
            <%= products.length > 0 ? (currentPage - 1) * limit + 1 : 0 %>–<%= Math.min(currentPage * limit, totalProducts) %>
          </span>
          of
          <span class="font-bold text-gray-900"><%= totalProducts %></span> results
        </span>

        <div class="flex items-center gap-2">
          <span class="text-sm text-gray-500 whitespace-nowrap">Sort by</span>
          <select onchange="applySort(this.value)"
                  class="border border-gray-300 bg-white rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-[#B88E2F]">
            <option value=""         <%= !sortParam              ? 'selected' : '' %>>Newest First</option>
            <option value="priceLow" <%= sortParam === 'priceLow'  ? 'selected' : '' %>>Price: Low to High</option>
            <option value="priceHigh"<%= sortParam === 'priceHigh' ? 'selected' : '' %>>Price: High to Low</option>
            <option value="aToZ"     <%= sortParam === 'aToZ'      ? 'selected' : '' %>>Name: A to Z</option>
            <option value="zToA"     <%= sortParam === 'zToA'      ? 'selected' : '' %>>Name: Z to A</option>
          </select>
        </div>
      </div>

    </div>
  </section>

  <%/* ── Main Content: Sidebar + Grid ───────────────────────────── */%>
  <section class="py-12 px-6 container mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-10">

      <%/* ── Sidebar ─────────────────────────────────────────────── */%>
      <aside class="space-y-8 lg:sticky lg:top-24 h-fit">

        <%/* Active Filters */%>
        <% if (selectedCategory || minPrice || maxPrice || searchQuery || selectedSizes.length > 0) { %>
          <div class="bg-gray-50 p-6 rounded-xl border border-gray-200">
            <div class="flex items-center justify-between mb-4">
              <h3 class="font-bold text-gray-900 text-base">Active Filters</h3>
              <a href="/shop" class="text-xs font-bold text-red-500 hover:text-red-700 transition-colors uppercase tracking-wider">Clear All</a>
            </div>
            <div class="flex flex-wrap gap-2">
              <% if (searchQuery) { %>
                <span class="bg-white border border-gray-300 text-gray-700 text-xs px-3 py-1 rounded-full flex items-center gap-1.5">
                  Search: "<%= searchQuery %>"
                  <button onclick="clearSearch()" class="text-gray-400 hover:text-gray-600"><i class="fas fa-times text-[10px]"></i></button>
                </span>
              <% } %>
              <% if (selectedCategory) { %>
                <span class="bg-[#B88E2F]/10 border border-[#B88E2F]/20 text-[#B88E2F] text-xs px-3 py-1 rounded-full flex items-center gap-1.5 font-medium">
                  <%= selectedCategory %>
                  <button onclick="applyCategory('')" class="text-[#B88E2F] hover:text-[#967325]"><i class="fas fa-times text-[10px]"></i></button>
                </span>
              <% } %>
              <% if (minPrice || maxPrice) { %>
                <span class="bg-green-50 border border-green-100 text-green-700 text-xs px-3 py-1 rounded-full flex items-center gap-1.5 font-medium">
                  Price: ₹<%= minPrice || 0 %> – <%= maxPrice ? '₹' + maxPrice : 'Max' %>
                  <button onclick="clearPriceRange()" class="text-green-500 hover:text-green-700"><i class="fas fa-times text-[10px]"></i></button>
                </span>
              <% } %>
              <% selectedSizes.forEach(sz => { %>
                <span class="bg-[#B88E2F]/10 border border-[#B88E2F]/20 text-[#B88E2F] text-xs px-3 py-1 rounded-full flex items-center gap-1.5 font-medium">
                  Size: <%= sz %>
                  <button onclick="toggleSizeFilter('<%= sz %>')" class="text-[#B88E2F] hover:text-[#967325]"><i class="fas fa-times text-[10px]"></i></button>
                </span>
              <% }) %>

            </div>
          </div>
        <% } %>

        <%/* Category Filter */%>
        <div class="border border-gray-100 p-6 rounded-xl shadow-sm">
          <h3 class="font-bold text-lg text-gray-900 border-b pb-3 mb-4">Categories</h3>
          <ul class="space-y-2.5 font-medium">
            <li>
              <button onclick="applyCategory('')"
                      class="w-full text-left py-1 text-sm transition-colors <%= !selectedCategory ? 'text-[#B88E2F] font-bold' : 'text-gray-600 hover:text-[#B88E2F]' %>">
                All Categories
              </button>
            </li>
            <% categories.forEach(cat => { %>
              <li>
                <button onclick="applyCategory('<%= cat %>')"
                        class="w-full text-left py-1 text-sm transition-colors uppercase tracking-wide text-xs <%= selectedCategory === cat ? 'text-[#B88E2F] font-bold' : 'text-gray-600 hover:text-[#B88E2F]' %>">
                  <%= cat %>
                </button>
              </li>
            <% }) %>
          </ul>
        </div>

        <%/* Price Filter */%>
        <div class="border border-gray-100 p-6 rounded-xl shadow-sm">
          <h3 class="font-bold text-lg text-gray-900 border-b pb-3 mb-4">Price Range</h3>
          <div class="space-y-4">
            <div class="grid grid-cols-2 gap-2">
              <div>
                <label class="text-xs text-gray-400 font-bold block mb-1">MIN PRICE</label>
                <input type="number" id="minPriceInput" value="<%= minPrice %>" placeholder="₹ 0"
                       class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:border-[#B88E2F]">
              </div>
              <div>
                <label class="text-xs text-gray-400 font-bold block mb-1">MAX PRICE</label>
                <input type="number" id="maxPriceInput" value="<%= maxPrice %>" placeholder="₹ Max"
                       class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:border-[#B88E2F]">
              </div>
            </div>
            <button onclick="applyPriceRange()"
                    class="w-full bg-[#B88E2F] text-white py-2 text-sm font-bold uppercase rounded-lg hover:bg-[#967325] transition-all shadow-sm">
              Apply Filter
            </button>
          </div>
        </div>

        <%/* Size Filter */%>
        <% if (locals.sizes && sizes.length > 0) { %>
          <div class="border border-gray-100 p-6 rounded-xl shadow-sm">
            <h3 class="font-bold text-lg text-gray-900 border-b pb-3 mb-4">Filter by Size</h3>
            <div class="space-y-2.5">
              <% sizes.forEach(sz => { %>
                <label class="flex items-center space-x-2.5 cursor-pointer text-sm text-gray-600 hover:text-[#B88E2F] transition-colors font-medium">
                  <input type="checkbox" name="sizes" value="<%= sz %>" <%= selectedSizes.includes(sz) ? 'checked' : '' %>
                         onchange="toggleSizeFilter('<%= sz %>')"
                         class="size-filter-checkbox rounded text-[#B88E2F] focus:ring-[#B88E2F] border-gray-300">
                  <span><%= sz %></span>
                </label>
              <% }) %>
            </div>
          </div>
        <% } %>



      </aside>

      <%/* ── Product Grid ─────────────────────────────────────────── */%>
      <div class="lg:col-span-3 space-y-12">

        <% if (products.length === 0) { %>
          <div class="text-center py-20 bg-gray-50 rounded-2xl border border-dashed border-gray-300 px-6">
            <div class="text-[#B88E2F] text-5xl mb-4"><i class="fas fa-couch"></i></div>
            <h2 class="text-2xl font-bold text-gray-800 mb-2">No Products Found</h2>
            <p class="text-gray-500 max-w-md mx-auto mb-6">
              We couldn't find any products matching your search criteria. Try adjusting your filters.
            </p>
            <a href="/shop" class="inline-block bg-[#B88E2F] text-white px-8 py-3 font-bold rounded-lg hover:bg-[#967325] transition-all shadow">
              Reset Filters
            </a>
          </div>

        <% } else { %>

          <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-8">
            <% products.forEach(product => { %>
              <%- include('./userPartials/product-card', { product }) %>
            <% }) %>
          </div>

          <%/* Pagination */%>
          <% if (totalPages > 1) { %>
            <div class="flex items-center justify-center gap-3 pt-8">

              <% if (currentPage > 1) { %>
                <button onclick="changePage('<%= currentPage - 1 %>')"
                        class="bg-[#F9F1E7] text-gray-800 px-4 py-3 rounded-lg font-semibold text-sm hover:bg-[#B88E2F] hover:text-white transition-all shadow-sm">
                  <i class="fas fa-chevron-left mr-1"></i> Prev
                </button>
              <% } %>

              <div class="flex items-center gap-2">
                <% for (let i = 1; i <= totalPages; i++) { %>
                  <button onclick="changePage('<%= i %>')"
                          class="w-11 h-11 rounded-lg text-sm font-bold transition-all shadow-sm <%= currentPage === i ? 'bg-[#B88E2F] text-white' : 'bg-[#F9F1E7] text-gray-800 hover:bg-[#B88E2F] hover:text-white' %>">
                    <%= i %>
                  </button>
                <% } %>
              </div>

              <% if (currentPage < totalPages) { %>
                <button onclick="changePage('<%= currentPage + 1 %>')"
                        class="bg-[#F9F1E7] text-gray-800 px-4 py-3 rounded-lg font-semibold text-sm hover:bg-[#B88E2F] hover:text-white transition-all shadow-sm">
                  Next <i class="fas fa-chevron-right ml-1"></i>
                </button>
              <% } %>

            </div>
          <% } %>

        <% } %>

      </div>

    </div>
  </section>

</main>

<script>
  function updateQueryParam(params) {
    const urlParams = new URLSearchParams(window.location.search);
    for (const [key, value] of Object.entries(params)) {
      if (value === null || value === '') {
        urlParams.delete(key);
      } else {
        urlParams.set(key, value);
      }
    }
    if (!params.hasOwnProperty('page')) urlParams.delete('page');
    window.location.search = urlParams.toString();
  }

  function applySort(val)    { updateQueryParam({ sort: val }); }
  function applyCategory(cat){ updateQueryParam({ category: cat }); }
  function applyPriceRange() {
    const min = document.getElementById('minPriceInput').value;
    const max = document.getElementById('maxPriceInput').value;
    updateQueryParam({ minPrice: min || '', maxPrice: max || '' });
  }
  function clearPriceRange() { updateQueryParam({ minPrice: '', maxPrice: '' }); }
  function clearSearch()     { updateQueryParam({ search: '' }); }
  function changePage(n)     { updateQueryParam({ page: n }); }

  function toggleSizeFilter(sz) {
    const urlParams = new URLSearchParams(window.location.search);
    let sizes = urlParams.get('sizes') ? urlParams.get('sizes').split(',') : [];
    const index = sizes.indexOf(sz);
    if (index > -1) {
      sizes.splice(index, 1);
    } else {
      sizes.push(sz);
    }
    updateQueryParam({ sizes: sizes.join(','), page: 1 });
  }


</script>


<script>
  /* ─────────────────────────────────────────────────────────────────
   * Add to Cart – shop card quick-add
   * Uses event delegation so it works for all cards, including any
   * that are injected dynamically.
   * A `processing` flag prevents duplicate requests from rapid clicks.
   * ───────────────────────────────────────────────────────────────── */
  (function () {
    // Guard: only register the listener once even if this script runs twice
    if (window.__shopCartListenerRegistered) return;
    window.__shopCartListenerRegistered = true;

    document.addEventListener('click', async function handleCardAddToCart(e) {
      const btn = e.target.closest('.card-add-to-cart');
      if (!btn) return;

      // Prevent duplicate requests while one is already in flight
      if (btn.dataset.processing === 'true') return;

      const productId = btn.dataset.productId;
      if (!productId) return;

      // Lock the button
      btn.dataset.processing = 'true';
      btn.disabled = true;
      const originalHTML = btn.innerHTML;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1"></i> Adding...';

      try {
        const res = await fetch('/cart/add', {
          method:  'POST',
          headers: { 'Content-Type': 'application/json' },
          body:    JSON.stringify({ productId, variantId: null, quantity: 1 })
        });

        // Handle unauthenticated users before parsing JSON
        if (res.status === 401) {
          window.location.href = '/login?error=Please login to add items to cart';
          return;
        }

        const data = await res.json();

        if (data.success) {
          if (window.updateCartBadgeCount && typeof data.cartCount === 'number') {
            window.updateCartBadgeCount(data.cartCount);
          }
          // Show SweetAlert toast (CDN loaded at top of this page)
          await Swal.fire({
            toast:             true,
            position:          'top-end',
            icon:              'success',
            title:             'Added to Cart!',
            text:              data.message || 'Product added successfully.',
            showConfirmButton: false,
            timer:             2000,
            timerProgressBar:  true
          });
        } else {
          await Swal.fire({
            icon:               'error',
            title:              'Could Not Add',
            text:               data.message || 'Something went wrong.',
            confirmButtonColor: '#B88E2F'
          });
        }

      } catch (err) {
        console.error('[AddToCart] Network/parse error:', err);
        await Swal.fire({
          icon:               'error',
          title:              'Network Error',
          text:               'Could not reach the server. Please try again.',
          confirmButtonColor: '#B88E2F'
        });
      } finally {
        // Always restore button state
        btn.innerHTML           = originalHTML;
        btn.disabled            = false;
        btn.dataset.processing  = 'false';
      }
    });
  })();
</script>

<%- include('../layout/footer') %>
