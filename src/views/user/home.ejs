<%- include('../layout/header') %>

<main class="bg-white">

  <%/* ══════════════════════════════════════════════════════════════
       HERO BANNER
     ══════════════════════════════════════════════════════════════ */%>
  <section class="relative w-full h-[500px] md:h-screen flex items-center justify-end overflow-hidden">

    <img src="/images/banner.png"
         class="absolute inset-0 w-full h-full object-cover -z-0"
         alt="Banner">

    <div class="container mx-auto px-6 relative z-10 flex justify-end">
      <div class="bg-[#FFF3E3] p-8 md:p-16 rounded-lg max-w-lg shadow-xl mr-0 md:mr-10">
        <p class="font-bold tracking-[3px] text-gray-800 mb-2 text-sm uppercase">NEW ARRIVAL</p>
        <h1 class="text-[#B88E2F] text-4xl md:text-6xl font-bold leading-tight mb-4">
          Discover Our <br> New Collection
        </h1>
        <p class="text-gray-600 mb-8 leading-relaxed">
          Experience the finest craftsmanship with our latest furniture designs, tailored for your modern lifestyle.
        </p>
        <a href="/shop" class="bg-[#B88E2F] text-white px-10 py-4 font-bold uppercase hover:bg-[#967325] transition-all inline-block">
          BUY NOW
        </a>
      </div>
    </div>
  </section>

  <%/* ══════════════════════════════════════════════════════════════
       SHOP BY SOFA TYPE
       `category` is the array of { name, img } sofa-type cards
     ══════════════════════════════════════════════════════════════ */%>
  <section class="py-20 px-6 container mx-auto">
    <div class="flex flex-col items-center mb-12 text-center border-b border-gray-100 pb-10">
      <div>
        <h2 class="text-4xl font-bold text-[#333333] tracking-tight">Shop by sofa type</h2>
        <p class="text-gray-500 mt-3 text-lg">Handpicked collections for your home.</p>
      </div>
      <div class="mt-8">
        <a href="/shop" class="inline-flex items-center gap-2 border border-[#B88E2F] text-[#B88E2F] px-8 py-3 font-bold hover:bg-[#B88E2F] hover:text-white transition-all text-sm uppercase tracking-wider rounded">
          Explore All
          <i class="fas fa-arrow-right text-xs"></i>
        </a>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <% category.forEach(cat => { %>
        <a href="/shop?category=<%= encodeURIComponent(cat.name) %>" class="group cursor-pointer block">
          <div class="overflow-hidden rounded-xl">
            <img src="<%= cat.img %>"
                 alt="<%= cat.name %>"
                 class="w-full h-[400px] object-cover transition-transform duration-500 group-hover:scale-110">
          </div>
          <h3 class="mt-6 font-bold text-xl text-[#333333]"><%= cat.name %></h3>
        </a>
      <% }) %>
    </div>
  </section>

  <%/* ══════════════════════════════════════════════════════════════
       OUR PRODUCTS — Dynamic from DB, 3 per row
     ══════════════════════════════════════════════════════════════ */%>
  <section class="py-16 px-6 container mx-auto">
    <h2 class="text-3xl font-bold text-center text-[#3A3A3A] mb-12">Our Products</h2>

    <% if (products && products.length > 0) { %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        <% products.forEach(product => { %>
          <%- include('./userPartials/product-card', { product }) %>
        <% }) %>
      </div>
    <% } else { %>
      <div class="text-center py-20 bg-gray-50 rounded-2xl border border-dashed border-gray-300">
        <div class="text-[#B88E2F] text-5xl mb-4"><i class="fas fa-couch"></i></div>
        <h3 class="text-2xl font-bold text-gray-800 mb-2">No Products Yet</h3>
        <p class="text-gray-500 mb-6">Products added by the admin will appear here automatically.</p>
        <a href="/shop" class="inline-block bg-[#B88E2F] text-white px-8 py-3 font-bold rounded-lg hover:bg-[#967325] transition-all">
          Browse Shop
        </a>
      </div>
    <% } %>

    <div class="text-center mt-12">
      <a href="/shop"
         class="inline-block border border-[#B88E2F] text-[#B88E2F] px-16 py-3.5 font-bold hover:bg-[#B88E2F] hover:text-white transition-all rounded">
        Show More
      </a>
    </div>
  </section>

</main>

<script>
  window.onpageshow = function (event) {
    if (event.persisted || (window.performance && window.performance.navigation.type === 2)) {
      window.location.reload();
    }
  };
</script>

<%- include('../layout/footer') %>