<%- include('../layout/header') %>

<main class="bg-white">

  <% if (locals.banners && banners.length > 0) { %>
    <section class="relative w-full h-[500px] md:h-[600px] overflow-hidden group">
      <!-- Slides wrapper -->
      <div id="sliderWrapper" class="flex w-full h-full transition-transform duration-700 ease-out">
        <% banners.forEach((banner, idx) => { %>
          <div class="w-full h-full shrink-0 relative flex items-center justify-start overflow-hidden">
            <img src="<%= banner.imageUrl.startsWith('http') ? banner.imageUrl : '/upload/banners/' + banner.imageUrl %>"
                 class="absolute inset-0 w-full h-full object-cover"
                 alt="<%= banner.title %>">
            <div class="absolute inset-0 bg-black/10"></div>
            
            <div class="container mx-auto px-6 relative z-10 flex justify-start">
              <div class="bg-[#FFF3E3]/95 backdrop-blur-sm p-8 md:p-14 rounded-2xl max-w-lg shadow-xl ml-0 md:ml-10 transition duration-300 hover:scale-[1.01]">
                <p class="font-bold tracking-[3px] text-gray-800 mb-2 text-xs md:text-sm uppercase">New Arrival</p>
                <h2 class="text-[#B88E2F] text-3xl md:text-5xl font-extrabold leading-tight mb-4 tracking-tight">
                  <%= banner.title %>
                </h2>
                <a href="/shop" class="bg-[#B88E2F] text-white px-8 py-3.5 font-bold text-xs md:text-sm uppercase rounded-xl hover:bg-[#967325] shadow-lg shadow-[#B88E2F]/20 hover:shadow-xl transition-all duration-300 inline-block">
                  BUY NOW
                </a>
              </div>
            </div>
          </div>
        <% }) %>
      </div>

      <!-- Controls -->
      <% if (banners.length > 1) { %>
        <button onclick="prevSlide()" class="absolute left-4 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-white/80 hover:bg-white text-gray-800 shadow-md flex items-center justify-center transition-all opacity-0 group-hover:opacity-100 z-20">
          <i class="fas fa-chevron-left text-xs"></i>
        </button>
        <button onclick="nextSlide()" class="absolute right-4 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-white/80 hover:bg-white text-gray-800 shadow-md flex items-center justify-center transition-all opacity-0 group-hover:opacity-100 z-20">
          <i class="fas fa-chevron-right text-xs"></i>
        </button>

        <!-- Indicators -->
        <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2 z-20">
          <% banners.forEach((_, idx) => { %>
            <button onclick="goToSlide(<%= idx %>)" class="slider-dot w-2.5 h-2.5 rounded-full bg-white/50 hover:bg-white transition-all focus:outline-none <%= idx === 0 ? 'bg-white w-6' : '' %>" data-index="<%= idx %>"></button>
          <% }) %>
        </div>
      <% } %>
    </section>
  <% } %>

  <%/* ══════════════════════════════════════════════════════════════
       SHOP BY SOFA TYPE
       `category` is the array of { name, img } sofa-type cards
     ══════════════════════════════════════════════════════════════ */%>
  <section class="py-20 px-6 container mx-auto">
    <div class="flex flex-col items-center mb-12 text-center border-b border-gray-100 pb-10">
      <div>
        <h2 class="text-4xl font-bold text-[#333333] tracking-tight">Shop by sofa type</h2>
        <p class="text-gray-500 mt-3 text-lg">Handpicked collections for your home.</p>
      </div>
      <div class="mt-8">
        <a href="/shop" class="inline-flex items-center gap-2 border border-[#B88E2F] text-[#B88E2F] px-8 py-3 font-bold hover:bg-[#B88E2F] hover:text-white transition-all text-sm uppercase tracking-wider rounded">
          Explore All
          <i class="fas fa-arrow-right text-xs"></i>
        </a>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <% category.forEach(cat => { %>
        <a href="/shop?category=<%= encodeURIComponent(cat.name) %>" class="group cursor-pointer block">
          <div class="overflow-hidden rounded-xl">
            <img src="<%= cat.img %>"
                 alt="<%= cat.name %>"
                 class="w-full h-[400px] object-cover transition-transform duration-500 group-hover:scale-110">
          </div>
          <h3 class="mt-6 font-bold text-xl text-[#333333]"><%= cat.name %></h3>
        </a>
      <% }) %>
    </div>
  </section>

  <%/* ══════════════════════════════════════════════════════════════
       OUR PRODUCTS — Dynamic from DB, 3 per row
     ══════════════════════════════════════════════════════════════ */%>
  <section class="py-16 px-6 container mx-auto">
    <h2 class="text-3xl font-bold text-center text-[#3A3A3A] mb-12">Our Products</h2>

    <% if (products && products.length > 0) { %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        <% products.forEach(product => { %>
          <%- include('./userPartials/product-card', { product }) %>
        <% }) %>
      </div>
    <% } else { %>
      <div class="text-center py-20 bg-gray-50 rounded-2xl border border-dashed border-gray-300">
        <div class="text-[#B88E2F] text-5xl mb-4"><i class="fas fa-couch"></i></div>
        <h3 class="text-2xl font-bold text-gray-800 mb-2">No Products Yet</h3>
        <p class="text-gray-500 mb-6">Products added by the admin will appear here automatically.</p>
        <a href="/shop" class="inline-block bg-[#B88E2F] text-white px-8 py-3 font-bold rounded-lg hover:bg-[#967325] transition-all">
          Browse Shop
        </a>
      </div>
    <% } %>

    <div class="text-center mt-12">
      <a href="/shop"
         class="inline-block border border-[#B88E2F] text-[#B88E2F] px-16 py-3.5 font-bold hover:bg-[#B88E2F] hover:text-white transition-all rounded">
        Show More
      </a>
    </div>
  </section>

</main>

<script>
  window.onpageshow = function (event) {
    if (event.persisted || (window.performance && window.performance.navigation.type === 2)) {
      window.location.reload();
    }
  };

  // Slider functionality
  let currentSlide = 0;
  const sliderWrapper = document.getElementById('sliderWrapper');
  const dots = document.querySelectorAll('.slider-dot');
  const slideCount = <%= (locals.banners && banners.length) ? banners.length : 0 %>;
  let autoSlideInterval;

  function updateSlider() {
    if (!sliderWrapper) return;
    sliderWrapper.style.transform = `translateX(-${currentSlide * 100}%)`;
    
    // Update dots
    dots.forEach((dot, idx) => {
      if (idx === currentSlide) {
        dot.classList.remove('bg-white/50');
        dot.classList.add('bg-white', 'w-6');
      } else {
        dot.classList.remove('bg-white', 'w-6');
        dot.classList.add('bg-white/50');
      }
    });
  }

  window.nextSlide = function() {
    if (slideCount <= 1) return;
    currentSlide = (currentSlide + 1) % slideCount;
    updateSlider();
    resetAutoSlide();
  };

  window.prevSlide = function() {
    if (slideCount <= 1) return;
    currentSlide = (currentSlide - 1 + slideCount) % slideCount;
    updateSlider();
    resetAutoSlide();
  };

  window.goToSlide = function(idx) {
    currentSlide = idx;
    updateSlider();
    resetAutoSlide();
  };

  function startAutoSlide() {
    if (slideCount <= 1) return;
    autoSlideInterval = setInterval(nextSlide, 5000); // Auto slide every 5 seconds
  }

  function resetAutoSlide() {
    clearInterval(autoSlideInterval);
    startAutoSlide();
  }

  // Initialize auto-sliding
  if (slideCount > 1) {
    startAutoSlide();
  }
</script>

<%- include('../layout/footer') %>