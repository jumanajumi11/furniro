<%- include('../layout/header') %>
<body class="text-gray-800">
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="flex flex-col lg:flex-row gap-8">
            <%- include('../layout/account-sidebar', { activePage: 'profile' }) %>

            <div class="flex-1 bg-white rounded-2xl shadow-sm border border-gray-100">
                <div class="p-8 border-b border-gray-100 flex justify-between items-center">
                    <h2 class="text-xl font-bold text-gray-900">Edit Profile</h2>
                    <a href="/profile" class="text-gray-400 hover:text-[#B88E2F] text-sm font-medium">Cancel</a>
                </div>

                <form id="profileForm" action="/profile" method="POST" enctype="multipart/form-data" class="p-8">
                    
                    <div class="flex flex-col items-center mb-10">
                        <div id="image-display" class="w-32 h-32 rounded-full flex items-center justify-center text-4xl font-bold text-white bg-[#B88E2F] border-4 border-gray-50 overflow-hidden shadow-md mb-4">
                            <% if (user && user.image) { %>
                                <img id="preview" src="<%= user.image.startsWith('http') ? user.image : '/upload/' + user.image %>" class="w-full h-full object-cover">
                            <% } else { %>
                                <span id="letter"><%= user.name ? user.name.charAt(0).toUpperCase() : 'U' %></span>
                            <% } %>
                        </div>
                        
                        <input type="file" name="image" id="fileInput" class="hidden" accept="image/*" onchange="previewImage(event)">
                        
                        <button type="button" onclick="document.getElementById('fileInput').click()" class="text-[#B88E2F] text-sm font-semibold hover:underline">
                            <i class="fas fa-camera mr-1"></i> Change Photo
                        </button>
                    </div>

                    <div class="space-y-6 max-w-2xl mx-auto">
                       
                    <div>
    <label class="block text-sm font-medium text-gray-700 mb-2">Full Name</label>
    <input type="text" name="name" value="<%= user.name %>" class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-[#B88E2F] outline-none">
    <p id="name-error" class="text-[11px] text-red-500 font-bold mt-1 hidden"></p>
</div>

<div>
    <label class="block text-sm font-medium text-gray-700 mb-2">Email Address</label>
    <input type="email" name="email" id="emailInput" value="<%= user.email %>" <% if (user.googleId) { %> readonly class="w-full px-4 py-3 border border-gray-200 rounded-lg bg-gray-100 cursor-not-allowed text-gray-500 outline-none" <% } else { %> class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-[#B88E2F] outline-none" <% } %>>
    <p id="email-error" class="text-[11px] text-red-500 font-bold mt-1 hidden"></p>
</div>

<div>
    <label class="block text-sm font-medium text-gray-700 mb-2">Phone Number</label>
    <input type="text" name="phone" id="phone" maxlength="10" value="<%= user.phone || '' %>" class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-[#B88E2F] outline-none">
    <p id="phone-error" class="text-[11px] text-red-500 font-bold mt-1 hidden"></p>
</div>

                    <div class="mt-10 flex justify-center">
                        <button type="button" onclick="handleProfileUpdate()" class="bg-[#B88E2F] hover:bg-[#A07B28] text-white px-12 py-3 rounded-lg font-medium shadow-md transition-all">
                            Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </main>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
let timerInterval;
let timeLeft = 60; 

function getEmailValidationError(rawEmail) {
    const email = rawEmail.trim();
    if (email === '') {
        return "Please enter a valid email address";
    }
    if (rawEmail.includes(' ')) {
        return "Email address should not contain spaces";
    }
    if (!rawEmail.includes('@')) {
        return "Please enter a valid email address with @";
    }
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(email)) {
        return "Please enter a valid email address";
    }
    return null;
}

document.addEventListener('DOMContentLoaded', () => {
    const inputs = document.querySelectorAll('#profileForm input');
    inputs.forEach(input => {
        input.addEventListener('input', function() {
            const fieldName = this.getAttribute('name');
            const val = this.value.trim();
            const errorElement = document.getElementById(`${fieldName === 'image' ? '' : fieldName}-error`);

            if (!errorElement) return;

            
            if (fieldName === 'phone') {
                if (/[^0-9]/.test(val)) {
                    errorElement.innerHTML = `<i class="fas fa-exclamation-circle"></i> Please enter numbers only!`;
                    errorElement.className = "text-[11px] text-red-500 font-bold mt-2 flex items-center gap-1";
                    errorElement.classList.remove('hidden');
                } else if (val !== '' && !/^\d{10}$/.test(val)) {
                    errorElement.innerHTML = `<i class="fas fa-exclamation-circle"></i> Phone number must be a 10-digit number`;
                    errorElement.className = "text-[11px] text-red-500 font-bold mt-2 flex items-center gap-1";
                    errorElement.classList.remove('hidden');
                } else {
                    errorElement.classList.add('hidden');
                }
            } 
            
            
            else if (fieldName === 'email') {
                const emailErrorMsg = getEmailValidationError(this.value);
                if (emailErrorMsg) {
                    errorElement.innerHTML = `<i class="fas fa-exclamation-circle"></i> ${emailErrorMsg}`;
                    errorElement.className = "text-[11px] text-red-500 font-bold mt-2 flex items-center gap-1";
                    errorElement.classList.remove('hidden');
                } else {
                    errorElement.classList.add('hidden');
                }
            }

            
            else if (fieldName === 'name') {
                if (val.length > 0 && val.length < 3) {
                    errorElement.innerHTML = `<i class="fas fa-exclamation-circle"></i> Name must be at least 3 characters!`;
                    errorElement.className = "text-[11px] text-red-500 font-bold mt-2 flex items-center gap-1";
                    errorElement.classList.remove('hidden');
                } else {
                    errorElement.classList.add('hidden');
                }
            }
        });
    });
});

function previewImage(event) {
    const reader = new FileReader();
    const file = event.target.files[0];
    if (file) {
        reader.onload = function() {
            const output = document.getElementById('image-display');
            output.innerHTML = `<img src="${reader.result}" class="w-full h-full object-cover">`;
        };
        reader.readAsDataURL(file);
    }
}


async function handleProfileUpdate() {
    const nameInput = document.getElementsByName('name')[0];
    const phoneInput = document.getElementById('phone');
    const emailInput = document.getElementById('emailInput');

    const name = nameInput.value.trim();
    const phone = phoneInput.value.trim();
    const newEmail = emailInput.value.trim();
    const rawEmail = emailInput.value;
    const currentEmail = "<%= user.email %>".trim();
    const isGoogleUser = "<%= user.googleId %>" ? true : false;

    // Reset Errors
    document.getElementById('name-error').classList.add('hidden');
    document.getElementById('phone-error').classList.add('hidden');
    const emailError = document.getElementById('email-error');
    emailError.classList.add('hidden');

    let hasError = false;

    if (name.length < 3) {
        const nameErr = document.getElementById('name-error');
        nameErr.innerHTML = `<i class="fas fa-exclamation-circle"></i> Name must be at least 3 characters!`;
        nameErr.className = "text-[11px] text-red-500 font-bold mt-2 flex items-center gap-1";
        nameErr.classList.remove('hidden');
        hasError = true;
    }

    const phoneRegex = /^\d{10}$/;
    if (phone && !phoneRegex.test(phone)) {
        const phoneErr = document.getElementById('phone-error');
        phoneErr.innerHTML = `<i class="fas fa-exclamation-circle"></i> Phone number must be a 10-digit number`;
        phoneErr.className = "text-[11px] text-red-500 font-bold mt-2 flex items-center gap-1";
        phoneErr.classList.remove('hidden');
        hasError = true;
    }

    // Email verification & validation on change
    if (!isGoogleUser && newEmail !== currentEmail) {
        const emailErrorMsg = getEmailValidationError(rawEmail);
        if (emailErrorMsg) {
            emailError.innerHTML = `<i class="fas fa-exclamation-circle"></i> ${emailErrorMsg}`;
            emailError.className = "text-[11px] text-red-500 font-bold mt-2 flex items-center gap-1";
            emailError.classList.remove('hidden');
            hasError = true;
        }
    }

    if (hasError) return;

    if (!isGoogleUser && newEmail !== currentEmail) {
        // Step 1: Send OTP first (do not open modal yet!)
        Swal.fire({
            title: 'Sending OTP...',
            allowOutsideClick: false,
            didOpen: () => { Swal.showLoading(); }
        });

        try {
            const response = await fetch('/send-email-otp', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ newEmail: newEmail })
            });
            const data = await response.json();

            if (!response.ok || !data.success) {
                Swal.fire('Error', data.message || 'Failed to send OTP.', 'error');
                return;
            }

            // OTP sent successfully. Now open the OTP verification modal!
            showOtpModal(newEmail);
        } catch (error) {
            Swal.fire('Error', 'Failed to connect. Please try again.', 'error');
        }
    } else {
        submitProfileData();
    }
}

async function submitProfileData() {
    const form = document.getElementById('profileForm');
    const formData = new FormData(form);

    Swal.fire({
        title: 'Saving changes...',
        allowOutsideClick: false,
        didOpen: () => { Swal.showLoading(); }
    });

    try {
        const response = await fetch('/profile', {
            method: 'PATCH',
            body: formData
        });
        const result = await response.json();

        if (response.status === 401 && result.isBlocked) {
            Swal.fire({
                icon: 'error',
                title: 'Blocked!',
                text: 'Your account is blocked by the admin.',
                confirmButtonColor: '#B88E2F',
                allowOutsideClick: false
            }).then(() => {
                window.location.href = '/login?error=Your account is blocked';
            });
            return;
        }

        if (result.success) {
            Swal.fire({ icon: 'success', title: 'Updated!', timer: 2000, showConfirmButton: false })
            .then(() => window.location.href = '/profile');
        } else {
            Swal.fire('Error', result.message, 'error');
        }
    } catch (error) {
        Swal.fire('Error', 'Update failed.', 'error');
    }
}

function showOtpModal(email) {
    let timeLeft = 60;
    let timerInterval;

    const startTimer = () => {
        const timerCount = document.getElementById('swal-timer-count');
        const resendBtn = document.getElementById('swal-resend-btn');
        const timerText = document.getElementById('swal-timer-text');

        if (resendBtn) {
            resendBtn.disabled = true;
            resendBtn.className = "text-gray-400 font-bold cursor-not-allowed ml-2";
        }
        if (timerText) {
            timerText.style.display = 'inline';
        }

        clearInterval(timerInterval);
        timerInterval = setInterval(() => {
            timeLeft--;
            if (timerCount) {
                const minutes = String(Math.floor(timeLeft / 60)).padStart(2, '0');
                const seconds = String(timeLeft % 60).padStart(2, '0');
                timerCount.textContent = `${minutes}:${seconds}`;
            }

            if (timeLeft <= 0) {
                clearInterval(timerInterval);
                if (timerText) {
                    timerText.style.display = 'none';
                }
                if (resendBtn) {
                    resendBtn.disabled = false;
                    resendBtn.className = "text-[#B88E2F] hover:underline font-bold cursor-pointer ml-2";
                }
            }
        }, 1000);
    };

    Swal.fire({
        title: 'Verify Your Email',
        html: `
            <p class="text-sm mb-4">Enter the 6-digit verification code sent to <br><b>${email}</b></p>
            <div class="flex justify-center mb-4">
                <input id="swal-otp-input" class="swal2-input text-center !w-48 tracking-[0.5em] font-bold" placeholder="------" maxlength="6">
            </div>
            <p id="swal-otp-error" class="text-[11px] text-red-500 font-bold mt-1 mb-3 hidden"></p>
            <p id="swal-otp-success" class="text-[11px] text-green-600 font-bold mt-1 mb-3 hidden"></p>
            <div class="text-sm">
                <span id="swal-timer-text">Resend OTP in <span id="swal-timer-count">01:00</span></span>
                <button type="button" id="swal-resend-btn" disabled class="text-gray-400 font-bold cursor-not-allowed ml-2" onclick="resendSwalOtp(event, '${email}')">Resend OTP</button>
            </div>
        `,
        showCancelButton: true,
        confirmButtonText: 'Verify & Update',
        confirmButtonColor: '#B88E2F',
        allowOutsideClick: false,
        didOpen: () => {
            startTimer();
        },
        willClose: () => {
            clearInterval(timerInterval);
        },
        preConfirm: async () => {
            const otpInput = document.getElementById('swal-otp-input');
            const errorElement = document.getElementById('swal-otp-error');
            const successElement = document.getElementById('swal-otp-success');
            const otp = otpInput.value.trim();

            if (errorElement) errorElement.classList.add('hidden');
            if (successElement) successElement.classList.add('hidden');

            if (!otp || otp.length !== 6) {
                errorElement.innerHTML = `<i class="fas fa-exclamation-circle"></i> Please enter 6-digit OTP.`;
                errorElement.classList.remove('hidden');
                return false;
            }

            if (timeLeft <= 0) {
                errorElement.innerHTML = `<i class="fas fa-exclamation-circle"></i> OTP expired! Please resend a new one.`;
                errorElement.classList.remove('hidden');
                return false;
            }

            Swal.showLoading();
            try {
                const response = await fetch('/verify-email-otp', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ otp })
                });
                const data = await response.json();

                if (!response.ok || !data.success) {
                    Swal.hideLoading();
                    errorElement.innerHTML = `<i class="fas fa-exclamation-circle"></i> ${data.message || 'Verification failed.'}`;
                    errorElement.classList.remove('hidden');
                    return false;
                }
                return true;
            } catch (error) {
                Swal.hideLoading();
                errorElement.innerHTML = `<i class="fas fa-exclamation-circle"></i> Failed to verify OTP. Please try again.`;
                errorElement.classList.remove('hidden');
                return false;
            }
        }
    }).then((result) => {
        if (result.isConfirmed) {
            submitProfileData();
        }
    });

    window.resendSwalOtp = async function(event, email) {
        if (event) {
            event.preventDefault();
            event.stopPropagation();
        }

        const resendBtn = document.getElementById('swal-resend-btn');
        const timerText = document.getElementById('swal-timer-text');
        const timerCount = document.getElementById('swal-timer-count');
        const errorElement = document.getElementById('swal-otp-error');
        const successElement = document.getElementById('swal-otp-success');

        // Clear existing timer immediately
        clearInterval(timerInterval);
        if (resendBtn) {
            resendBtn.disabled = true;
            resendBtn.className = "text-gray-400 font-bold cursor-not-allowed ml-2";
        }
        if (timerText) {
            timerText.style.display = 'inline';
        }
        if (timerCount) {
            timerCount.textContent = '01:00';
        }
        if (errorElement) {
            errorElement.classList.add('hidden');
        }
        if (successElement) {
            successElement.classList.add('hidden');
        }

        try {
            const response = await fetch('/send-email-otp', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ newEmail: email })
            });
            const data = await response.json();
            if (!response.ok || !data.success) {
                if (errorElement) {
                    errorElement.innerHTML = `<i class="fas fa-exclamation-circle"></i> ${data.message || 'Failed to resend OTP.'}`;
                    errorElement.classList.remove('hidden');
                }
                if (resendBtn) {
                    resendBtn.disabled = false;
                    resendBtn.className = "text-[#B88E2F] hover:underline font-bold cursor-pointer ml-2";
                }
                if (timerText) {
                    timerText.style.display = 'none';
                }
                return;
            }

            timeLeft = 60;
            startTimer();

            // Clear input field
            const otpInput = document.getElementById('swal-otp-input');
            if (otpInput) {
                otpInput.value = '';
            }

            if (successElement) {
                successElement.textContent = "OTP has been resent successfully";
                successElement.classList.remove('hidden');
            }
        } catch (error) {
            if (errorElement) {
                errorElement.innerHTML = `<i class="fas fa-exclamation-circle"></i> Failed to resend OTP. Please try again.`;
                errorElement.classList.remove('hidden');
            }
            if (resendBtn) {
                resendBtn.disabled = false;
                resendBtn.className = "text-[#B88E2F] hover:underline font-bold cursor-pointer ml-2";
            }
            if (timerText) {
                timerText.style.display = 'none';
            }
        }
    };
}
</script>
</body>