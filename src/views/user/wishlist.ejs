<%- include('../layout/header') %>
<!-- SweetAlert2 CDN for alerts and toasts -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
  .unavailable-option {
      position: relative !important;
      overflow: hidden !important;
      opacity: 0.4 !important;
      cursor: not-allowed !important;
  }
  .unavailable-option::after {
      content: "" !important;
      position: absolute !important;
      top: 50% !important;
      left: -10% !important;
      width: 120% !important;
      height: 1.5px !important;
      background-color: #ef4444 !important;
      transform: translateY(-50%) rotate(-45deg) !important;
      transform-origin: center !important;
      pointer-events: none !important;
  }
</style>

<main class="bg-white min-h-screen">
  <%/* ── Wishlist Main Section ────────────────────────────────────── */%>
  <section class="container mx-auto px-6 py-16">
    <% if (!products || products.length === 0) { %>
      <%/* ── Empty Wishlist State ── */%>
      <div class="text-center py-20 bg-gray-50 rounded-2xl border border-dashed border-gray-300 max-w-xl mx-auto px-6">
        <div class="text-[#B88E2F] text-6xl mb-6">
          <i class="far fa-heart"></i>
        </div>
        <h2 class="text-2xl font-bold text-gray-800 mb-2">Your Wishlist is Empty</h2>
        <p class="text-gray-500 max-w-md mx-auto mb-8">
          Explore our collections and add your favorite items to your wishlist.
        </p>
        <a href="/shop" class="inline-block bg-[#B88E2F] text-white px-8 py-3.5 font-bold rounded-lg hover:bg-[#967325] transition-all shadow-md">
          Explore Shop
        </a>
      </div>
    <% } else { %>
      <%/* ── Wishlist Items Grid ── */%>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8" id="wishlist-grid">
        <% products.forEach(prod => { 
            let imgUrl = 'https://placehold.co/400x400?text=No+Image';
            if (prod.images && prod.images.length > 0) {
                const firstImg = prod.images[0];
                imgUrl = firstImg.startsWith('http') ? firstImg : '/upload/products/' + firstImg;
            } else if (prod.colors && prod.colors.length > 0) {
                const defCol = prod.colors.find(c => c.isDefault) || prod.colors[0];
                if (defCol && defCol.images && defCol.images.length > 0) {
                    const colImg = defCol.images[0];
                    imgUrl = colImg.startsWith('http') ? colImg : '/upload/products/' + colImg;
                }
            }
            const isOutOfStock = prod.stock <= 0;
            const price = prod.salePrice || prod.regularPrice || 0;
        %>
          <div class="bg-[#F4F5F7] rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-all flex flex-col h-full border border-gray-100 relative group" id="wishlist-item-<%= prod._id %>">
            
            <%/* ── Image & Out of stock ribbon ── */%>
            <div class="relative h-64 overflow-hidden shrink-0">
              <% if (isOutOfStock) { %>
                <span class="absolute top-4 left-4 z-10 bg-red-500 text-white text-xs px-3 py-1 font-bold rounded shadow-sm uppercase">
                  Out of Stock
                </span>
              <% } %>
              
              <button onclick="removeWishlistItem(this, '<%= prod._id %>')" 
                      class="absolute top-4 right-4 z-10 bg-white/80 hover:bg-white text-gray-500 hover:text-red-500 w-8 h-8 rounded-full flex items-center justify-center transition-colors shadow-sm focus:outline-none"
                      title="Remove from wishlist">
                <i class="fas fa-trash-alt text-xs"></i>
              </button>

              <a href="/shop/product/<%= prod._id %>" class="block w-full h-full">
                <img src="<%= imgUrl %>" alt="<%= prod.productName %>" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105">
              </a>
            </div>

            <%/* ── Details & Actions ── */%>
            <div class="p-5 flex flex-col flex-grow">
              <h3 class="font-bold text-gray-800 text-base mb-1 truncate">
                <a href="/shop/product/<%= prod._id %>" class="hover:text-[#B88E2F] transition-colors"><%= prod.productName %></a>
              </h3>
              <p class="text-gray-400 text-xs font-semibold uppercase tracking-wider mb-4 truncate">
                <%= prod.category ? prod.category.name : 'Uncategorized' %>
              </p>

              <div class="mt-auto">
                <div class="flex flex-col gap-0.5 mb-4">
                  <div class="flex items-center gap-2">
                    <span class="font-bold text-lg text-gray-900">₹<%= price.toLocaleString('en-IN') %></span>
                    <% if (prod.salePrice && prod.regularPrice > prod.salePrice) { %>
                      <span class="text-gray-400 line-through text-xs font-semibold">₹<%= prod.regularPrice.toLocaleString('en-IN') %></span>
                      <span class="bg-[#E97171] text-white text-[9px] font-bold px-1.5 py-0.5 rounded">
                        <%= Math.round((1 - prod.salePrice / prod.regularPrice) * 100) %>% OFF
                      </span>
                    <% } %>
                  </div>
                  <% if (prod.salePrice && prod.regularPrice > prod.salePrice) { %>
                    <p class="text-green-600 text-[10px] font-black tracking-tight">
                      You Save ₹<%= (prod.regularPrice - prod.salePrice).toLocaleString('en-IN') %>
                    </p>
                  <% } %>
                </div>
                <% if (prod.variants && prod.variants.length > 0) { %>
<div class="mb-4">
    <p class="text-xs text-gray-500 font-semibold mb-2">
        Available Sizes
    </p>

    <div class="flex flex-wrap gap-2">
        <% 
        const predefinedSizes = ['S','M','L'];

        predefinedSizes.forEach(sz => {

            const sizeVariants = prod.variants.filter(
                v => v.size === sz
            );

            const hasStock = sizeVariants.some(
                v => v.stock > 0
            );

            const variantExists = sizeVariants.length > 0;
        %>

            <% if(variantExists && hasStock){ %>

                <span
                    class="px-3 py-1 text-xs font-semibold border rounded-md bg-white text-gray-700">
                    <%= sz %>
                </span>

            <% } else if(variantExists && !hasStock){ %>

                <span
                    class="px-3 py-1 text-xs font-semibold border rounded-md bg-gray-100 text-gray-400 cursor-not-allowed relative">

                    <%= sz %>

                    <span
                        class="block text-[9px] text-red-500 font-bold">
                        Out of Stock
                    </span>

                </span>

            <% } else { %>

                <span
                    class="px-3 py-1 text-xs font-semibold border rounded-md bg-gray-100 text-gray-400 cursor-not-allowed relative unavailable-option">

                    <%= sz %>

                    <span
                        class="block text-[9px] text-gray-400 font-bold">
                        Unavailable
                    </span>

                </span>

            <% } %>

        <% }) %>
    </div>
</div>
<% } %>

                <div class="space-y-2.5">
                  <% if (!isOutOfStock) { %>
                    <button onclick="openVariantModal('<%= prod._id %>')" 
                            class="w-full bg-[#B88E2F] hover:bg-[#967325] text-white font-bold text-sm py-2.5 px-4 rounded-lg flex items-center justify-center gap-2 transition-colors shadow-sm focus:outline-none uppercase">
                      <i class="fas fa-expand text-xs"></i> SELECT SIZE
                    </button>
                  <% } else { %>
                    <button disabled 
                            class="w-full bg-gray-300 text-gray-500 font-bold text-sm py-2.5 px-4 rounded-lg cursor-not-allowed flex items-center justify-center gap-2">
                      <i class="fas fa-times-circle text-xs"></i> Out of Stock
                    </button>
                  <% } %>
                </div>
              </div>
            </div>

          </div>
        <% }) %>
      </div>
    <% } %>
  </section>

  <!-- Premium Variant Selection Modal -->
  <div id="variant-modal" class="fixed inset-0 z-50 flex items-center justify-center hidden">
    <!-- Modal Backdrop -->
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm transition-opacity duration-300 opacity-0" id="modal-backdrop" onclick="closeVariantModal()"></div>
    
    <!-- Modal Content Card -->
    <div class="relative bg-white w-full max-w-lg md:max-w-2xl mx-4 rounded-3xl shadow-2xl overflow-hidden border border-gray-100 flex flex-col md:flex-row transform scale-95 opacity-0 transition-all duration-300 max-h-[90vh] md:max-h-[80vh]" id="modal-card">
      
      <!-- Close Button -->
      <button onclick="closeVariantModal()" class="absolute top-4 right-4 text-gray-400 hover:text-gray-900 w-8 h-8 rounded-full bg-gray-50 flex items-center justify-center transition-all focus:outline-none z-10">
        <i class="fas fa-times"></i>
      </button>

      <!-- Left Side: Product Image Display -->
      <div class="w-full md:w-1/2 bg-[#F9F1E7] p-6 flex flex-col items-center justify-center min-h-[200px] md:min-h-full shrink-0 relative">
        <img id="modal-product-img" src="" alt="Product Image" class="max-w-full max-h-48 md:max-h-64 object-contain transition-transform duration-500 hover:scale-105">
      </div>

      <!-- Right Side: Details & Selectors -->
      <div class="w-full md:w-1/2 p-6 flex flex-col justify-between overflow-y-auto">
        <div>
          <!-- Category & Badge -->
          <div class="flex items-center gap-2 mb-2">
            <span id="modal-product-category" class="bg-[#B88E2F]/10 text-[#B88E2F] text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded">
              Category
            </span>
            <span id="modal-stock-badge" class="text-[10px] font-bold px-2 py-0.5 rounded">
              In Stock
            </span>
          </div>

          <!-- Title -->
          <h3 id="modal-product-name" class="text-xl font-bold text-gray-900 mb-3 leading-snug">Product Title</h3>

          <!-- Price Display -->
          <div class="bg-gray-50 p-4 rounded-xl border border-gray-100/60 mb-4 space-y-1">
            <div class="flex items-baseline gap-2">
              <span id="modal-display-price" class="text-2xl font-black text-[#B88E2F]">₹0</span>
              <span id="modal-display-regular-price" class="text-sm text-gray-400 line-through font-semibold hidden">₹0</span>
              <span id="modal-discount-badge" class="bg-red-500 text-white text-[10px] font-bold px-1.5 py-0.5 rounded hidden">0% OFF</span>
            </div>
            <p id="modal-savings-text" class="text-xs text-green-600 font-bold hidden">You Save ₹0</p>
          </div>

          <!-- Variant Options -->
          <div class="space-y-4">
            <!-- Colors Section -->
            <div id="modal-color-section" class="hidden">
              <span class="text-xs font-bold text-gray-400 uppercase tracking-wider block mb-2">Select Color</span>
              <div class="flex items-center gap-3" id="modal-color-options">
                <!-- Color buttons populated dynamically -->
              </div>
            </div>

            <!-- Sizes Section -->
            <div id="modal-size-section" class="hidden">
              <span class="text-xs font-bold text-gray-400 uppercase tracking-wider block mb-2">Select Size</span>
              <div class="flex flex-wrap gap-2" id="modal-size-options">
                <!-- Size buttons populated dynamically -->
              </div>
            </div>
          </div>
        </div>

        <!-- Confirm Action Button -->
        <div class="mt-6 pt-4 border-t border-gray-100">
          <div id="modal-validation-error" class="hidden bg-red-50 border border-red-200 text-red-600 text-xs font-semibold px-3 py-2 rounded-lg mb-3 flex items-center gap-1.5 animate-pulse">
            <i class="fas fa-exclamation-circle text-sm"></i>
            <span id="modal-validation-text">Please select options</span>
          </div>
          <button id="modal-confirm-btn" onclick="confirmMoveToCart()" class="w-full bg-[#B88E2F] hover:bg-[#967325] text-white font-bold text-sm py-3 px-4 rounded-xl flex items-center justify-center gap-2 transition-all shadow-md focus:outline-none">
            <i class="fas fa-shopping-cart text-xs"></i> ADD TO CART
          </button>
        </div>

      </div>

    </div>
  </div>
</main>

<script id="wishlist-products-data" type="application/json">
  <%- JSON.stringify(products) %>
</script>
<script>
  // AJAX: Remove product from wishlist directly
  async function removeWishlistItem(btn, productId) {
      try {
          const result = await Swal.fire({
              title: 'Remove Item?',
              text: 'Are you sure you want to remove this item from your wishlist?',
              icon: 'warning',
              showCancelButton: true,
              confirmButtonColor: '#B88E2F',
              cancelButtonColor: '#d33',
              confirmButtonText: 'Yes, remove it'
          });

          if (!result.isConfirmed) return;

          // Disable button to prevent double-clicks
          if (btn) btn.disabled = true;

          const response = await fetch('/wishlist/remove', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ productId })
          });

          const data = await response.json();

          // Handle unauthorized access (session expired)
          if (response.status === 401) {
              window.location.href = data.redirectUrl || '/login?error=Please login to perform this action';
              return;
          }

          if (!response.ok) {
              throw new Error(data.message || 'Could not remove item');
          }

          // Remove element from grid
          const itemEl = document.getElementById(`wishlist-item-${productId}`);
          if (itemEl) {
              itemEl.remove();
          }

          // Sync badge count
          if (window.updateWishlistBadgeCount) {
              window.updateWishlistBadgeCount(data.wishlistCount);
          }

          // If wishlist is empty, refresh page to show empty state
          if (data.wishlistCount === 0) {
              window.location.reload();
          } else {
              Swal.fire({
                  icon: 'success',
                  title: 'Removed!',
                  text: 'Product removed from your wishlist.',
                  toast: true,
                  position: 'top-end',
                  showConfirmButton: false,
                  timer: 2000,
                  timerProgressBar: true
              });
          }

      } catch (error) {
          console.error('Remove wishlist error:', error);
          if (btn) btn.disabled = false;
          Swal.fire({
              icon: 'error',
              title: 'Error',
              text: error.message || 'Something went wrong',
              confirmButtonColor: '#B88E2F'
          });
      }
  }

  // Serialize products to JSON for client side access
  const wishlistProducts = JSON.parse(document.getElementById('wishlist-products-data').textContent);

  // Selected state tracking variables
  let selectedProduct = null;
  let selectedColor = "";
  let selectedSize = "";
  let currentVariant = null;

  // Open variant modal and initialize values
  function openVariantModal(productId) {
      selectedProduct = wishlistProducts.find(p => p._id === productId);
      if (!selectedProduct) return;

      const productOffer = selectedProduct.productOffer || 0;
      const categoryOffer = selectedProduct.categoryOffer || 0;
      const effectiveOffer = selectedProduct.effectiveOffer || 0;
      const finalPrice = selectedProduct.finalPrice || selectedProduct.regularPrice || 0;

      console.log("Product:", selectedProduct.productName);
      console.log("Product Offer:", productOffer);
      console.log("Category Offer:", categoryOffer);
      console.log("Effective Offer:", effectiveOffer);
      console.log("Final Price:", finalPrice);

      selectedColor = "";
      selectedSize = "";
      currentVariant = null;

      // Hide validation error
      document.getElementById('modal-validation-error').classList.add('hidden');

      // Populate details
      document.getElementById('modal-product-name').textContent = selectedProduct.productName;
      document.getElementById('modal-product-category').textContent = selectedProduct.category ? selectedProduct.category.name : 'Uncategorized';

      const primaryImg = (selectedProduct.images && selectedProduct.images.length > 0)
          ? (selectedProduct.images[0].startsWith('http') ? selectedProduct.images[0] : '/upload/products/' + selectedProduct.images[0])
          : 'https://placehold.co/400x400?text=No+Image';
      document.getElementById('modal-product-img').src = primaryImg;

      const hasVariants = selectedProduct.variants && selectedProduct.variants.length > 0;

      if (hasVariants) {
          // Collect ALL unique sizes and colors from every variant (including 0-stock ones)
          const allSizes  = ['S','M','L'];
          const allColors = [...new Set(selectedProduct.variants.map(v => v.color).filter(Boolean))];

          // ── Colors Section ─────────────────────────────────────────────
          const colorSection = document.getElementById('modal-color-section');
          if (allColors.length > 0) {
              colorSection.classList.remove('hidden');
              const colorContainer = document.getElementById('modal-color-options');
              colorContainer.innerHTML = "";
              allColors.forEach(colName => {
                  const colorObj = (selectedProduct.colors || []).find(c => c.name.toLowerCase() === colName.toLowerCase());
                  const hex = colorObj ? colorObj.hex : "#CCCCCC";

                  const btn = document.createElement('button');
                  btn.type = "button";
                  btn.title = colName;
                  btn.className = `w-7 h-7 rounded-full border-2 border-gray-300 transition-all focus:outline-none hover:scale-110 shadow-xs modal-color-btn relative overflow-hidden`;
                  btn.style.backgroundColor = hex;
                  btn.setAttribute('data-color', colName);
                  colorContainer.appendChild(btn);
              });
          } else {
              colorSection.classList.add('hidden');
          }

          // ── Sizes Section ───────────────────────────────────────────────
          const sizeSection = document.getElementById('modal-size-section');
          if (allSizes.length > 0) {
              sizeSection.classList.remove('hidden');
              const sizeContainer = document.getElementById('modal-size-options');
              sizeContainer.innerHTML = "";
              allSizes.forEach(sz => {
                  const btn = document.createElement('button');
                  btn.type = "button";
                  // Start with a placeholder class; updateModalOptions will style it properly
                  btn.className = `px-3 py-1.5 border border-gray-200 text-gray-700 font-semibold text-xs rounded-lg transition-all focus:outline-none modal-size-btn min-w-[50px] flex flex-col items-center justify-center relative overflow-hidden`;
                  btn.setAttribute('data-size', sz);
                  btn.innerHTML = `<span>${sz}</span>`;
                  sizeContainer.appendChild(btn);
              });
          } else {
              sizeSection.classList.add('hidden');
          }

          // Pre-select the first in-stock variant's size AND color
          // so the modal opens in a fully valid state
          const firstInStockVariant = selectedProduct.variants.find(v => v.stock > 0);
          const fallbackVariant     = selectedProduct.variants[0];
          const seedVariant         = firstInStockVariant || fallbackVariant;
          if (seedVariant) {
              selectedSize  = seedVariant.size  || '';
              selectedColor = seedVariant.color || '';
          }

          updateModalOptions();
          calculateModalVariant();
      } else {
          document.getElementById('modal-color-section').classList.add('hidden');
          document.getElementById('modal-size-section').classList.add('hidden');
          calculateModalVariant();
      }

      // Display Modal with animation
      const modal = document.getElementById('variant-modal');
      const backdrop = document.getElementById('modal-backdrop');
      const card = document.getElementById('modal-card');

      modal.classList.remove('hidden');
      modal.classList.add('flex');

      setTimeout(() => {
          backdrop.classList.remove('opacity-0');
          backdrop.classList.add('opacity-100');
          card.classList.remove('scale-95', 'opacity-0');
          card.classList.add('scale-100', 'opacity-100');
      }, 10);
  }

  function closeVariantModal() {
      const modal = document.getElementById('variant-modal');
      const backdrop = document.getElementById('modal-backdrop');
      const card = document.getElementById('modal-card');

      backdrop.classList.remove('opacity-100');
      backdrop.classList.add('opacity-0');
      card.classList.remove('scale-100', 'opacity-100');
      card.classList.add('scale-95', 'opacity-0');

      setTimeout(() => {
          modal.classList.add('hidden');
          modal.classList.remove('flex');
      }, 300);
  }

  function selectModalColor(colorName) {
      selectedColor = colorName;

      // Update modal image
      const colorObj = selectedProduct.colors.find(c => c.name.toLowerCase() === colorName.toLowerCase());
      const mainImg = document.getElementById('modal-product-img');
      if (colorObj && colorObj.images && colorObj.images.length > 0) {
          const colImg = colorObj.images[0];
          mainImg.src = colImg.startsWith('http') ? colImg : '/upload/products/' + colImg;
      } else {
          const primaryImg = (selectedProduct.images && selectedProduct.images.length > 0)
              ? (selectedProduct.images[0].startsWith('http') ? selectedProduct.images[0] : '/upload/products/' + selectedProduct.images[0])
              : 'https://placehold.co/400x400?text=No+Image';
          mainImg.src = primaryImg;
      }

      updateModalOptions();
      calculateModalVariant();
  }

  function selectModalSize(sizeName) {
      selectedSize = sizeName;

      // Find first variant for this size that has stock > 0
      const activeColorVar = selectedProduct.variants.find(v => v.size === sizeName && v.stock > 0);
      if (activeColorVar) {
          selectedColor = activeColorVar.color;
      } else {
          // Fallback to first variant of this size
          const anyColorVar = selectedProduct.variants.find(v => v.size === sizeName);
          if (anyColorVar) {
              selectedColor = anyColorVar.color;
          }
      }

      updateModalOptions();
      calculateModalVariant();
  }

  function updateModalOptions() {
      // ── 1. Update Size Buttons ─────────────────────────────────────
      //
      // Availability rules:
      //   • If a color IS selected  → check the specific (size + color) pair
      //   • If no color is selected → check whether ANY variant of this size has stock > 0
      //
      const sizeButtons = document.querySelectorAll('.modal-size-btn');
      sizeButtons.forEach(btn => {
          const sizeVal = btn.getAttribute('data-size');

          // All variants that share this size
          const sizeVariants = selectedProduct.variants.filter(v => v.size === sizeVal);

          let sizeState; // 'selected' | 'available' | 'oos' | 'unavailable'
          let pairVariant = null;

          if (!selectedColor) {
              // No color chosen yet — evaluate globally across all colors
              if (sizeVariants.length === 0) {
                  sizeState = 'unavailable'; // no variant has this size at all
              } else if (sizeVariants.some(v => v.stock > 0)) {
                  sizeState = (selectedSize === sizeVal) ? 'selected' : 'available';
              } else {
                  sizeState = 'oos'; // variants exist but all are 0-stock
              }
          } else {
              // A color is selected — evaluate only the (size + color) pair
              pairVariant = sizeVariants.find(v => v.color === selectedColor);
              if (!pairVariant) {
                  // No variant for this size+color combination
                  // But show it as OOS only if it exists in ANY color (size exists globally)
                  sizeState = sizeVariants.length > 0 ? 'oos' : 'unavailable';
              } else if (pairVariant.stock <= 0) {
                  sizeState = 'oos';
              } else {
                  sizeState = (selectedSize === sizeVal) ? 'selected' : 'available';
              }
          }

          // Apply classes & event handlers
          const BASE = 'modal-size-btn min-w-[50px] flex flex-col items-center justify-center relative overflow-hidden rounded-lg text-xs font-semibold transition-all focus:outline-none';

          btn.onclick   = null;
          btn.disabled  = false;
          btn.removeAttribute('title');

          if (sizeState === 'selected') {
              btn.className = `${BASE} px-3 py-1.5 bg-white border-2 border-[#B88E2F] text-[#B88E2F] font-bold shadow-sm`;
              btn.innerHTML = `<span>${sizeVal}</span>`;
              btn.onclick   = () => selectModalSize(sizeVal);

          } else if (sizeState === 'available') {
              btn.className = `${BASE} px-3 py-1.5 border border-gray-300 text-gray-700 bg-white cursor-pointer hover:border-[#B88E2F] hover:text-[#B88E2F]`;
              btn.innerHTML = `<span>${sizeVal}</span>`;
              btn.onclick   = () => selectModalSize(sizeVal);

          } else if (sizeState === 'oos') {
              // Out-of-stock: show with diagonal red strike-through
              btn.className = `${BASE} px-3 py-1.5 border border-gray-200 text-gray-400 bg-gray-50 cursor-not-allowed unavailable-option`;
              btn.disabled  = true;
              btn.title     = selectedColor ? `Out of stock in ${selectedColor}` : 'Out of stock';
              btn.innerHTML = `<span>${sizeVal}</span><span class="text-[8px] text-red-500 font-bold block mt-0.5">Out of Stock</span>`;

          } else { // 'unavailable'
              btn.className = `${BASE} px-3 py-1.5 border border-gray-200 text-gray-400 bg-gray-50 cursor-not-allowed unavailable-option`;
              btn.disabled  = true;
              btn.title     = 'Unavailable';
              btn.innerHTML = `<span>${sizeVal}</span><span class="text-[8px] text-gray-400 font-bold block mt-0.5">Unavailable</span>`;
          }
      });

      // ── 2. Update Color Buttons ────────────────────────────────────
      //
      // If a size is selected → check (size + color) pair
      // If no size selected   → show all colors as available
      //
      const colorButtons = document.querySelectorAll('.modal-color-btn');
      colorButtons.forEach(btn => {
          const colName = btn.getAttribute('data-color');

          // Reset
          btn.disabled = false;
          btn.classList.remove('unavailable-option', 'opacity-50', 'cursor-not-allowed', 'ring-2', 'ring-[#B88E2F]', 'ring-offset-2', 'border-[#B88E2F]', 'border-gray-300');
          btn.removeAttribute('title');
          btn.style.outline = '';
          btn.onclick = () => selectModalColor(colName);

          if (selectedSize) {
              const pairVariant = selectedProduct.variants.find(v => v.size === selectedSize && v.color === colName);

              if (!pairVariant) {
                  // Color doesn't exist for this size
                  btn.classList.add('unavailable-option');
                  btn.disabled = true;
                  btn.onclick  = null;
                  btn.title    = `Unavailable in size ${selectedSize}`;
              } else if (pairVariant.stock <= 0) {
                  // Exists but OOS
                  btn.classList.add('opacity-50', 'cursor-not-allowed', 'unavailable-option');
                  btn.disabled = true;
                  btn.onclick  = null;
                  btn.title    = `${colName} – Out of stock in size ${selectedSize}`;
              } else {
                  btn.title = colName;
              }
          } else {
              // No size selected yet — check if this color has any in-stock variant
              const hasStock = selectedProduct.variants.some(v => v.color === colName && v.stock > 0);
              if (!hasStock) {
                  btn.classList.add('opacity-50', 'cursor-not-allowed');
                  btn.title = `${colName} – Out of stock`;
              } else {
                  btn.title = colName;
              }
          }

          // Highlight selected color
          if (selectedColor === colName) {
              btn.classList.add('ring-2', 'ring-[#B88E2F]', 'ring-offset-2', 'border-[#B88E2F]');
          } else {
              btn.classList.add('border-gray-300');
          }
      });
  }

  function calculateModalVariant() {
      if (!selectedProduct.variants || selectedProduct.variants.length === 0) {
          updateModalDisplay(selectedProduct.regularPrice, selectedProduct.salePrice, selectedProduct.stock, false);
          return;
      }

      // If both size and color are selected, find the exact pair
      if (selectedSize && selectedColor) {
          currentVariant = selectedProduct.variants.find(v => v.color === selectedColor && v.size === selectedSize);
      } else if (selectedSize && !selectedColor) {
          // Only size is selected — find best available variant of this size
          currentVariant = selectedProduct.variants.find(v => v.size === selectedSize && v.stock > 0)
                        || selectedProduct.variants.find(v => v.size === selectedSize)
                        || null;
      } else {
          currentVariant = null;
      }

      if (currentVariant) {
          updateModalDisplay(currentVariant.price, currentVariant.salePrice || null, currentVariant.stock, false);
      } else {
          updateModalDisplay(selectedProduct.regularPrice, selectedProduct.salePrice, 0, true);
      }
  }

  function updateModalDisplay(price, salePrice, stock, isUnavailable) {
      const displayPriceEl = document.getElementById('modal-display-price');
      const regularPriceEl = document.getElementById('modal-display-regular-price');
      const discountEl = document.getElementById('modal-discount-badge');
      const savingsEl = document.getElementById('modal-savings-text');
      const badgeEl = document.getElementById('modal-stock-badge');
      const confirmBtn = document.getElementById('modal-confirm-btn');

      const displayAmt = salePrice || price || 0;
      displayPriceEl.textContent = `₹${displayAmt.toLocaleString('en-IN')}`;

      if (salePrice && price && price > salePrice) {
          regularPriceEl.textContent = `₹${price.toLocaleString('en-IN')}`;
          regularPriceEl.classList.remove('hidden');

          const pct = Math.round((1 - salePrice / price) * 100);
          discountEl.textContent = `${pct}% OFF`;
          discountEl.classList.remove('hidden');

          const diff = price - salePrice;
          savingsEl.textContent = `You Save ₹${diff.toLocaleString('en-IN')}`;
          savingsEl.classList.remove('hidden');
      } else {
          regularPriceEl.classList.add('hidden');
          discountEl.classList.add('hidden');
          savingsEl.classList.add('hidden');
      }

      if (isUnavailable) {
          badgeEl.className = "text-[10px] font-bold px-2 py-0.5 rounded bg-gray-100 text-gray-500";
          badgeEl.textContent = "Unavailable";
          confirmBtn.disabled = true;
          confirmBtn.classList.add('opacity-50', 'cursor-not-allowed');
      } else if (stock === 0) {
          badgeEl.className = "text-[10px] font-bold px-2 py-0.5 rounded bg-red-100 text-red-700";
          badgeEl.textContent = "Out of Stock";
          confirmBtn.disabled = true;
          confirmBtn.classList.add('opacity-50', 'cursor-not-allowed');
      } else if (stock >= 1 && stock <= 5) {
          badgeEl.className = "text-[10px] font-bold px-2 py-0.5 rounded bg-orange-100 text-orange-700";
          badgeEl.textContent = `Low Stock (${stock})`;
          confirmBtn.disabled = false;
          confirmBtn.classList.remove('opacity-50', 'cursor-not-allowed');
      } else {
          badgeEl.className = "text-[10px] font-bold px-2 py-0.5 rounded bg-green-100 text-green-700";
          badgeEl.textContent = "In Stock";
          confirmBtn.disabled = false;
          confirmBtn.classList.remove('opacity-50', 'cursor-not-allowed');
      }
  }

  async function confirmMoveToCart() {
      const errorEl = document.getElementById('modal-validation-error');
      const errorTextEl = document.getElementById('modal-validation-text');
      errorEl.classList.add('hidden');

      if (!selectedProduct) return;

      const hasVariants = selectedProduct.variants && selectedProduct.variants.length > 0;
      if (hasVariants) {
          if (!selectedSize) {
              errorTextEl.textContent = "Please select a size.";
              errorEl.classList.remove('hidden');
              return;
          }

          const colors = [...new Set(selectedProduct.variants.map(v => v.color).filter(Boolean))];
          if (colors.length > 0 && !selectedColor) {
              errorTextEl.textContent = "Please select a color.";
              errorEl.classList.remove('hidden');
              return;
          }

          if (!currentVariant) {
              errorTextEl.textContent = "The selected option is unavailable.";
              errorEl.classList.remove('hidden');
              return;
          }

          if (currentVariant.stock <= 0) {
              errorTextEl.textContent = "The selected variant is out of stock.";
              errorEl.classList.remove('hidden');
              return;
          }
      } else {
          if (selectedProduct.stock <= 0) {
              errorTextEl.textContent = "This product is out of stock.";
              errorEl.classList.remove('hidden');
              return;
          }
      }

      const confirmBtn = document.getElementById('modal-confirm-btn');
      const originalText = confirmBtn.innerHTML;
      confirmBtn.disabled = true;
      confirmBtn.innerHTML = `<i class="fas fa-spinner fa-spin text-xs"></i> Adding...`;

      try {
          const response = await fetch('/wishlist/move-to-cart', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                  productId: selectedProduct._id,
                  variantId: currentVariant ? currentVariant._id : null
              })
          });

          const data = await response.json();

          if (response.status === 401) {
              window.location.href = data.redirectUrl || '/login?error=Please login to perform this action';
              return;
          }

          if (!response.ok || !data.success) {
              throw new Error(data.message || 'Could not add product to cart');
          }

          closeVariantModal();

          const itemEl = document.getElementById(`wishlist-item-${selectedProduct._id}`);
          if (itemEl) {
              itemEl.remove();
          }

          if (window.updateCartBadgeCount) {
              window.updateCartBadgeCount(data.cartCount);
          }
          if (window.updateWishlistBadgeCount) {
              window.updateWishlistBadgeCount(data.wishlistCount);
          }

          Swal.fire({
              icon: 'success',
              title: 'Added to Cart!',
              text: 'The product variant was successfully added to your cart and removed from wishlist.',
              showCancelButton: true,
              confirmButtonColor: '#B88E2F',
              cancelButtonColor: '#888',
              confirmButtonText: 'Go to Cart',
              cancelButtonText: 'Continue Shopping'
          }).then((result) => {
              if (result.isConfirmed) {
                  window.location.href = '/cart';
              } else if (data.wishlistCount === 0) {
                  window.location.reload();
              }
          });

      } catch (error) {
          console.error('Move to cart error:', error);
          Swal.fire({
              icon: 'error',
              title: 'Action Failed',
              text: error.message || 'Could not add product to cart',
              confirmButtonColor: '#B88E2F'
          });
      } finally {
          confirmBtn.disabled = false;
          confirmBtn.innerHTML = originalText;
      }
  }
</script>

