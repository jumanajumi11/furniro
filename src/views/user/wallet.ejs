<%- include('../layout/header') %>

<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="text-sm text-gray-500 mb-8 flex items-center gap-2">
        <a href="/" class="hover:text-[#B88E2F]">Home</a>
        <i class="fas fa-chevron-right text-xs"></i>
        <span class="text-gray-800">My Account</span>
    </div>

    <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900 mb-2">My Wallet</h1>
        <p class="text-gray-500">Manage your account funds and view transaction logs.</p>
    </div>

    <div class="flex flex-col lg:flex-row gap-8">
        <!-- Sidebar Navigation -->
        <%- include('../layout/account-sidebar', { activePage: 'wallet' }) %>

        <!-- Wallet Dashboard Contents -->
        <div class="flex-1 space-y-8">
            
            <div class="max-w-md">
                <!-- Large Balance Card -->
                <div class="bg-gradient-to-br from-[#B88E2F] to-[#8E6A21] rounded-3xl p-6 text-white shadow-md relative overflow-hidden flex flex-col justify-between min-h-[180px]">
                    <div class="absolute -right-6 -bottom-6 w-32 h-32 bg-white/5 rounded-full z-0"></div>
                    <div class="absolute -right-2 -top-2 w-20 h-20 bg-white/5 rounded-full z-0"></div>
                    <div class="flex justify-between items-start relative z-10">
                        <div>
                            <p class="text-xs uppercase tracking-widest text-white/70 font-semibold">Wallet Balance</p>
                            <h2 class="text-3xl font-extrabold mt-1" id="display-wallet-balance">₹<%= (user.wallet || 0).toLocaleString('en-IN') %></h2>
                        </div>
                        <i class="fas fa-wallet text-3xl text-white/40"></i>
                    </div>
                    <div class="mt-8 relative z-10">
                        <p class="text-[10px] uppercase tracking-widest text-white/50 font-semibold">Account Holder</p>
                        <p class="font-bold text-sm text-white/90 mt-0.5"><%= user.name || 'Customer' %></p>
                    </div>
                </div>
            </div>

            <!-- Transaction logs -->
            <div class="bg-white border border-gray-100 rounded-3xl p-6 shadow-sm">
                <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-6">
                    <h3 class="font-extrabold text-gray-800 text-base flex items-center gap-2">
                        <i class="fas fa-list text-[#B88E2F]"></i>
                        Transaction History
                        <% if (typeof totalTransactions !== 'undefined') { %>
                            <span class="text-xs font-semibold text-gray-400">(<%= totalTransactions %> total)</span>
                        <% } %>
                    </h3>

                    <!-- Filter Tabs -->
                    <div class="flex gap-2">
                        <a href="/wallet?filter=all&page=1" class="px-3 py-1.5 rounded-xl text-xs font-bold transition-all <%= filter === 'all' ? 'bg-[#B88E2F] text-white shadow' : 'bg-gray-100 text-gray-600 hover:bg-gray-200' %>">
                            All
                        </a>
                        <a href="/wallet?filter=credit&page=1" class="px-3 py-1.5 rounded-xl text-xs font-bold transition-all <%= filter === 'credit' ? 'bg-green-600 text-white shadow' : 'bg-green-50 text-green-700 hover:bg-green-100' %>">
                            <i class="fas fa-arrow-down text-[10px]"></i> Credits
                        </a>
                        <a href="/wallet?filter=debit&page=1" class="px-3 py-1.5 rounded-xl text-xs font-bold transition-all <%= filter === 'debit' ? 'bg-red-600 text-white shadow' : 'bg-red-50 text-red-700 hover:bg-red-100' %>">
                            <i class="fas fa-arrow-up text-[10px]"></i> Debits
                        </a>
                    </div>
                </div>

                <!-- Desktop Table -->
                <div class="hidden sm:block overflow-x-auto">
                    <table class="w-full text-left border-collapse text-xs">
                        <thead>
                            <tr class="border-b border-gray-100 text-gray-400 uppercase tracking-wider font-bold">
                                <th class="py-3 pr-4">Date & Time</th>
                                <th class="py-3 px-4">Description</th>
                                <th class="py-3 px-4 text-center">Type</th>
                                <th class="py-3 px-4 text-center">Status</th>
                                <th class="py-3 pl-4 text-right">Amount</th>
                            </tr>
                        </thead>
                        <tbody id="transaction-body">
                            <% if (transactions && transactions.length > 0) { %>
                                <% transactions.forEach(tx => { %>
                                    <tr class="border-b border-gray-50 text-gray-600 font-medium hover:bg-gray-50/50 transition-colors">
                                        <td class="py-4 pr-4 whitespace-nowrap">
                                            <%= new Date(tx.createdAt || tx.transactionDate).toLocaleString('en-IN', { dateStyle: 'medium', timeStyle: 'short' }) %>
                                        </td>
                                        <td class="py-4 px-4 font-bold text-gray-800 max-w-[280px] truncate" title="<%= tx.description %>"><%= tx.description %></td>
                                        <td class="py-4 px-4 text-center">
                                            <span class="px-2 py-0.5 rounded text-[9px] font-bold uppercase tracking-wider <%= tx.type === 'credit' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' %>">
                                                <%= tx.type %>
                                            </span>
                                        </td>
                                        <td class="py-4 px-4 text-center">
                                            <span class="px-2 py-0.5 rounded text-[9px] font-bold uppercase tracking-wider
                                                <% if (tx.status === 'completed') { %>bg-emerald-50 text-emerald-700
                                                <% } else if (tx.status === 'pending') { %>bg-yellow-50 text-yellow-700
                                                <% } else { %>bg-gray-100 text-gray-600<% } %>">
                                                <%= tx.status || 'completed' %>
                                            </span>
                                        </td>
                                        <td class="py-4 pl-4 text-right font-extrabold <%= tx.type === 'credit' ? 'text-green-600' : 'text-red-500' %>">
                                            <%= tx.type === 'credit' ? '+' : '-' %>₹<%= tx.amount.toLocaleString('en-IN') %>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="5" class="py-12 text-center">
                                        <i class="fas fa-receipt text-4xl text-gray-200 mb-3 block"></i>
                                        <p class="text-gray-400 font-bold text-sm">No transactions recorded yet.</p>
                                        <p class="text-gray-300 text-xs mt-1">Your wallet activity will appear here.</p>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>

                <!-- Mobile Cards -->
                <div class="sm:hidden space-y-3">
                    <% if (transactions && transactions.length > 0) { %>
                        <% transactions.forEach(tx => { %>
                            <div class="border border-gray-100 rounded-2xl p-4 hover:shadow-sm transition-shadow">
                                <div class="flex items-center justify-between mb-2">
                                    <span class="px-2 py-0.5 rounded text-[9px] font-bold uppercase tracking-wider <%= tx.type === 'credit' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' %>">
                                        <%= tx.type %>
                                    </span>
                                    <span class="font-extrabold text-sm <%= tx.type === 'credit' ? 'text-green-600' : 'text-red-500' %>">
                                        <%= tx.type === 'credit' ? '+' : '-' %>₹<%= tx.amount.toLocaleString('en-IN') %>
                                    </span>
                                </div>
                                <p class="font-bold text-sm text-gray-800 truncate" title="<%= tx.description %>"><%= tx.description %></p>
                                <div class="flex items-center justify-between mt-2">
                                    <span class="text-[10px] text-gray-400 font-semibold">
                                        <%= new Date(tx.createdAt || tx.transactionDate).toLocaleString('en-IN', { dateStyle: 'medium', timeStyle: 'short' }) %>
                                    </span>
                                    <span class="px-2 py-0.5 rounded text-[8px] font-bold uppercase tracking-wider
                                        <% if (tx.status === 'completed') { %>bg-emerald-50 text-emerald-700
                                        <% } else if (tx.status === 'pending') { %>bg-yellow-50 text-yellow-700
                                        <% } else { %>bg-gray-100 text-gray-600<% } %>">
                                        <%= tx.status || 'completed' %>
                                    </span>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div class="py-12 text-center">
                            <i class="fas fa-receipt text-4xl text-gray-200 mb-3 block"></i>
                            <p class="text-gray-400 font-bold text-sm">No transactions recorded yet.</p>
                            <p class="text-gray-300 text-xs mt-1">Your wallet activity will appear here.</p>
                        </div>
                    <% } %>
                </div>

                <!-- Pagination -->
                <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
                    <div class="flex flex-wrap items-center justify-center gap-2 mt-6 pt-4 border-t border-gray-100">
                        <% if (currentPage > 1) { %>
                            <a href="/wallet?filter=<%= filter %>&page=<%= currentPage - 1 %>" 
                               class="px-3 py-1.5 rounded-xl text-xs font-bold bg-gray-100 text-gray-600 hover:bg-gray-200 transition-all">
                                <i class="fas fa-chevron-left"></i> Prev
                            </a>
                        <% } %>

                        <% 
                            let startPage = Math.max(1, currentPage - 2);
                            let endPage = Math.min(totalPages, currentPage + 2);
                            if (endPage - startPage < 4) {
                                if (startPage === 1) endPage = Math.min(totalPages, startPage + 4);
                                else startPage = Math.max(1, endPage - 4);
                            }
                        %>
                        
                        <% if (startPage > 1) { %>
                            <a href="/wallet?filter=<%= filter %>&page=1" class="px-3 py-1.5 rounded-xl text-xs font-bold bg-gray-100 text-gray-600 hover:bg-gray-200 transition-all">1</a>
                            <% if (startPage > 2) { %>
                                <span class="text-gray-400 text-xs">...</span>
                            <% } %>
                        <% } %>

                        <% for (let i = startPage; i <= endPage; i++) { %>
                            <a href="/wallet?filter=<%= filter %>&page=<%= i %>" 
                               class="px-3 py-1.5 rounded-xl text-xs font-bold transition-all <%= i === currentPage ? 'bg-[#B88E2F] text-white shadow' : 'bg-gray-100 text-gray-600 hover:bg-gray-200' %>">
                                <%= i %>
                            </a>
                        <% } %>

                        <% if (endPage < totalPages) { %>
                            <% if (endPage < totalPages - 1) { %>
                                <span class="text-gray-400 text-xs">...</span>
                            <% } %>
                            <a href="/wallet?filter=<%= filter %>&page=<%= totalPages %>" class="px-3 py-1.5 rounded-xl text-xs font-bold bg-gray-100 text-gray-600 hover:bg-gray-200 transition-all"><%= totalPages %></a>
                        <% } %>

                        <% if (currentPage < totalPages) { %>
                            <a href="/wallet?filter=<%= filter %>&page=<%= currentPage + 1 %>" 
                               class="px-3 py-1.5 rounded-xl text-xs font-bold bg-gray-100 text-gray-600 hover:bg-gray-200 transition-all">
                                Next <i class="fas fa-chevron-right"></i>
                            </a>
                        <% } %>
                    </div>
                <% } %>
            </div>

        </div>
    </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<%- include('../layout/footer') %>
