<%
  /* ── field helpers ───────────────────────────────────────────── */
  let cardImg = 'https://placehold.co/400x400?text=No+Image';
  if (product.images && product.images.length > 0) {
      cardImg = '/upload/products/' + product.images[0];
  } else if (product.colors && product.colors.length > 0) {
      const defaultColor = product.colors.find(c => c.isDefault) || product.colors[0];
      if (defaultColor && defaultColor.images && defaultColor.images.length > 0) {
          cardImg = '/upload/products/' + defaultColor.images[0];
      }
  }
  const cardName      = product.productName || 'Unnamed Product';
  const cardCatName   = (product.category && product.category.name)
                          ? product.category.name : '';
  const cardPrice     = product.salePrice || product.regularPrice || 0;
  const cardOrigPrice = product.salePrice ? product.regularPrice : null;
  const cardDiscount  = (product.salePrice && product.regularPrice)
                          ? Math.round((1 - product.salePrice / product.regularPrice) * 100)
                          : 0;
  const cardStock     = product.stock || 0;
  const cardIsNew     = (function(){
    const d = new Date(product.createdAt);
    return (Date.now() - d.getTime()) < (14 * 24 * 60 * 60 * 1000);
  })();
  const detailUrl     = '/shop/product/' + product._id;
%>

<%/* ═══════════════════════════════════════════════════════════════
   CARD ROOT
   - NOT wrapped in <a> — the overlay buttons and the text links
     below each handle their own navigation independently.
   - overflow-hidden is kept on the CARD so border-radius clips
     the image, but we cannot use it AND have a full-card overlay
     intercept clicks, so the overlay is scoped to the image only.
════════════════════════════════════════════════════════════════ */%>
<div class="bg-[#F4F5F7] group relative rounded-xl shadow-sm hover:shadow-lg transition-shadow duration-300 flex flex-col">

  <%/* ── IMAGE SECTION (overlay scoped here, not on whole card) ── */%>
  <div class="relative overflow-hidden rounded-t-xl h-72 shrink-0">

    <%/* ── Badge ── */%>
    <% if (cardDiscount > 0) { %>
      <div class="absolute top-4 right-4 z-20 bg-[#E97171] text-white w-12 h-12 rounded-full flex items-center justify-center font-bold text-sm shadow-sm pointer-events-none">
        -<%= cardDiscount %>%
      </div>
    <% } else if (cardIsNew) { %>
      <div class="absolute top-4 right-4 z-20 bg-[#2EC1AC] text-white w-12 h-12 rounded-full flex items-center justify-center font-bold text-sm shadow-sm pointer-events-none">
        New
      </div>
    <% } %>

    <%/* ── Out-of-stock ribbon ── */%>
    <% if (cardStock <= 0) { %>
      <span class="absolute top-4 left-4 z-20 bg-red-500 text-white text-xs px-3 py-1 font-bold rounded shadow-sm uppercase pointer-events-none">
        Out of Stock
      </span>
    <% } %>

    <%/* ── Product image (always navigable) ── */%>
    <a href="<%= detailUrl %>" class="block w-full h-full" aria-label="View <%= cardName %> details">
      <img src="<%= cardImg %>"
           alt="<%= cardName %>"
           class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
           loading="lazy">
    </a>

    <%/* ── Hover overlay — scoped to image div only ──────────────────
         KEY FIX:
         1. pointer-events-none when invisible → clicks fall through to <a>
         2. group-hover:pointer-events-auto only when visible
         3. Contains its OWN "View Details" <a> + the Add to Cart button
            so the user can navigate OR add to cart from the overlay
         4. inset-0 is relative to this image div, NOT the whole card
    ── */%>
    <div class="absolute inset-0 bg-black/50
                flex flex-col items-center justify-center gap-3
                opacity-0 group-hover:opacity-100
                pointer-events-none group-hover:pointer-events-auto
                transition-opacity duration-300 z-10">

      <%/* Add to Cart button */%>
      <% if (cardStock > 0) { %>
        <button
          class="card-add-to-cart bg-white text-[#B88E2F] px-10 py-2.5 font-bold text-sm shadow-md
                 hover:bg-[#B88E2F] hover:text-white transition-colors duration-200 rounded-lg
                 focus:outline-none focus:ring-2 focus:ring-[#B88E2F] focus:ring-offset-2"
          data-product-id="<%= product._id %>"
          type="button"
          aria-label="Add <%= cardName %> to cart">
          <i class="fas fa-shopping-cart mr-1.5"></i> Add to cart
        </button>
      <% } else { %>
        <button disabled type="button"
          class="bg-gray-300 text-gray-500 px-10 py-2.5 font-bold text-sm rounded-lg cursor-not-allowed shadow-inner">
          Out of Stock
        </button>
      <% } %>

      <%/* View Details navigation link */%>
      <a href="<%= detailUrl %>"
         class="text-white font-semibold text-sm border border-white/60 px-8 py-2 rounded-lg
                hover:bg-white hover:text-[#B88E2F] transition-colors duration-200"
         aria-label="View details of <%= cardName %>">
        <i class="fas fa-eye mr-1.5"></i> View Details
      </a>

      <%/* Share / Like row */%>
      <div class="flex text-white gap-6 font-semibold text-xs mt-1">
        <span class="flex items-center gap-1 cursor-pointer hover:text-[#B88E2F] transition-colors">
          <i class="fas fa-share"></i> Share
        </span>
        <button type="button" onclick="event.preventDefault(); event.stopPropagation(); handleWishlistToggle('<%= product._id %>')" 
                class="flex items-center gap-1 cursor-pointer hover:text-red-400 transition-colors focus:outline-none">
          <% 
             const isWishlisted = locals.wishlistProductIds && locals.wishlistProductIds.includes(product._id.toString());
          %>
          <i id="like-icon-<%= product._id %>" class="<%= isWishlisted ? 'fas text-red-500' : 'far text-white' %> fa-heart"></i> 
          <span id="like-text-<%= product._id %>"><%= isWishlisted ? 'Liked' : 'Like' %></span>
        </button>
      </div>

    </div><%/* end overlay */%>

  </div><%/* end image section */%>

  <%/* ── Product info — ALWAYS clickable, never covered by overlay ── */%>
  <div class="p-5 flex flex-col flex-grow">

    <h3 class="text-base font-bold text-[#3A3A3A] truncate mb-0.5">
      <a href="<%= detailUrl %>" class="hover:text-[#B88E2F] transition-colors">
        <%= cardName %>
      </a>
    </h3>
    <p class="text-gray-400 text-[10px] font-semibold uppercase tracking-wider truncate mb-2">
      <%= cardCatName %>
    </p>

    <% if (product.variants && product.variants.length > 0) { %>
      <div class="mt-1 mb-3 flex flex-wrap items-center gap-1.5">
        <span class="text-[9px] font-bold text-gray-400 mr-0.5">Sizes:</span>
        <% 
           const uniqueSizes = [...new Set(product.variants.map(v => v.size).filter(Boolean))];
           uniqueSizes.forEach(sz => {
             const hasStock = product.variants.some(v => v.size === sz && v.stock > 0);
        %>
          <span class="px-1.5 py-0.5 text-[9px] font-bold border border-gray-250 rounded bg-white <%= hasStock ? 'text-gray-700' : 'text-gray-400 line-through bg-gray-100/50' %>">
            <%= sz %>
          </span>
        <% }) %>
      </div>
    <% } %>

    <div class="flex items-center justify-between mt-auto">
      <div class="flex flex-wrap items-center gap-2">
        <p class="font-bold text-base text-[#3A3A3A]">
          Rp <%= (typeof cardPrice === 'number') ? cardPrice.toLocaleString('id-ID') : cardPrice %>
        </p>
        <% if (cardOrigPrice) { %>
          <p class="text-gray-400 line-through text-xs font-semibold">
            Rp <%= (typeof cardOrigPrice === 'number') ? cardOrigPrice.toLocaleString('id-ID') : cardOrigPrice %>
          </p>
        <% } %>
      </div>

      <span class="text-[10px] font-bold <%= cardStock > 0 ? 'text-green-600' : 'text-red-500' %>">
        <i class="fas <%= cardStock > 0 ? 'fa-check-circle' : 'fa-times-circle' %> mr-0.5"></i>
        <%= cardStock > 0 ? 'In Stock' : 'Out of Stock' %>
      </span>
    </div>

  </div><%/* end product info */%>

</div><%/* end card root */%>
