<%- include('../layout/header') %>

<main class="min-h-[70vh] flex items-center justify-center bg-gradient-to-b from-[#FCF9F4] to-white py-16 px-4">
    <div class="max-w-2xl w-full text-center">
        <!-- Floating Animation for a themed chair icon/illustration -->
        <div class="relative w-48 h-48 mx-auto mb-10 animate-bounce" style="animation-duration: 3s;">
            <!-- Themed 404 Backdrop -->
            <span class="absolute inset-0 flex items-center justify-center text-[10rem] font-extrabold text-[#B88E2F]/10 select-none">404</span>
            
            <!-- Styled Modern Chair SVG -->
            <div class="absolute inset-0 flex items-center justify-center">
                <svg class="w-32 h-32 text-[#B88E2F]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <!-- Lounge/Accent Chair outline -->
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m-15 0a3 3 0 0 1-3-3V7.5A2.25 2.25 0 0 1 5.25 5.25h13.5A2.25 2.25 0 0 1 21 7.5V9a3 3 0 0 1-3 3m-13.5 0v3.75m0 0h13.5m-13.5 0v3m13.5-3v3m-10.5-6.75h7.5M8.25 12V8.25M15.75 12V8.25" />
                </svg>
            </div>
        </div>

        <h1 class="text-4xl md:text-5xl font-extrabold text-gray-950 mb-4 tracking-tight">
            Oops! This piece is missing.
        </h1>
        <p class="text-gray-500 text-lg max-w-md mx-auto mb-10 font-medium leading-relaxed">
            The page you are looking for might have been moved, deleted, or is currently under construction.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
            <a href="/" class="w-full sm:w-auto px-8 py-4 bg-[#B88E2F] text-white font-bold rounded-full hover:bg-[#a17a26] transition-all duration-300 shadow-lg shadow-amber-700/10 hover:shadow-xl active:scale-98 uppercase tracking-wider text-sm">
                Back to Home
            </a>
            <a href="/profile" class="w-full sm:w-auto px-8 py-4 bg-white border-2 border-gray-200 text-gray-800 font-bold rounded-full hover:border-[#B88E2F] hover:text-[#B88E2F] transition-all duration-300 active:scale-98 uppercase tracking-wider text-sm">
                My Profile
            </a>
        </div>
    </div>
</main>

<%- include('../layout/footer') %>
