<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | Welcome Back</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>

<body class="bg-gray-50 flex items-center justify-center min-h-screen p-4">

<div class="bg-white p-8 rounded-2xl shadow-xl w-full max-w-md border border-gray-100">
    
    <!-- Header -->
    <div class="text-center mb-8">
        <h1 class="text-3xl font-bold text-gray-900">Welcome Back</h1>
        <p class="text-gray-400 text-sm mt-1">Please enter your details</p>
    </div>

    <!-- Error Message -->
    <% if (locals.error) { %>
        <div class="mb-4 p-3 bg-red-50 border-l-4 border-red-500 text-red-700 text-xs rounded">
            <%= error %>
        </div>
    <% } %>

    
    <!-- Login Form -->
<form action="/login" method="POST" id="loginForm" class="space-y-4" novalidate>

    <!-- Email -->
    <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1">Email</label>
        <input type="text" name="email" id="email" placeholder="name@example.com" 
            class="w-full px-4 py-3 bg-gray-200 rounded-full focus:ring-2 focus:ring-yellow-600 outline-none">
        
        <span id="emailError" class="text-red-500 text-xs ml-4 mt-1 block"></span>
    </div>

    <!-- Password -->
    <div>
        <div class="flex justify-end mb-1">
            <a href="/forgot-password" class="text-xs font-semibold hover:underline">
                Forgot Password?
            </a>
        </div>

        <label class="block text-sm font-semibold text-gray-700 mb-1">Password</label>

        <div class="relative">
            <input type="password" id="password" name="password" placeholder="Enter password" 
                class="w-full px-4 py-3 bg-gray-200 rounded-full focus:ring-2 focus:ring-yellow-600 outline-none">

            <span onclick="togglePassword()" class="absolute right-4 top-3 cursor-pointer">
                👁️
            </span>
        </div>
        
        <span id="passwordError" class="text-red-500 text-xs ml-4 mt-1 block"></span>
    </div>

    <!-- Submit -->
    <button type="submit"
        class="w-full py-3 bg-[#c0943c] hover:bg-[#a67d2e] text-white font-bold rounded-full">
        Log in
    </button>
</form>

    <!-- Divider -->
    <div class="flex items-center my-6">
        <div class="flex-grow border-t"></div>
        <span class="px-3 text-xs text-gray-500">OR</span>
        <div class="flex-grow border-t"></div>
    </div>

    <!-- ✅ GOOGLE BUTTON (IMPORTANT PART) -->
    <a href="/auth/google"
       class="w-full py-3 bg-gray-200 hover:bg-gray-300 flex items-center justify-center gap-3 rounded-full font-semibold text-gray-700 transition-all">

        <img src="https://www.gstatic.com/images/branding/product/1x/googleg_48dp.png"
             class="w-5 h-5" alt="Google">

        Continue with Google
    </a>

    <!-- Signup -->
    <div class="text-center mt-6 text-sm">
        <span class="text-gray-500">Don't have an account?</span>
        <a href="/signup" class="font-bold hover:underline">Sign up</a>
    </div>

</div>

<!-- Password Toggle Script -->
<script>
    document.getElementById('loginForm').addEventListener('submit', function (e) {
    let isValid = true;

    
    const email = document.getElementById('email').value.trim();
    const password = document.getElementById('password').value.trim();

    
    document.getElementById('emailError').textContent = "";
    document.getElementById('passwordError').textContent = "";

    // 1. Email Validation
    const emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (email === "") {
        document.getElementById('emailError').textContent = "Email is required";
        isValid = false;
    } else if (!emailPattern.test(email)) {
        document.getElementById('emailError').textContent = "Please enter a valid email address";
        isValid = false;
    }

    // 2. Password Validation
    if (password === "") {
        document.getElementById('passwordError').textContent = "Password is required";
        isValid = false;
    } else if (password.length < 6) {
        document.getElementById('passwordError').textContent = "Password must be at least 6 characters";
        isValid = false;
    }

    
    if (!isValid) {
        e.preventDefault();
    }
});

// Clear validation errors in real-time as user types
document.getElementById('email').addEventListener('input', function() {
    document.getElementById('emailError').textContent = "";
});
document.getElementById('password').addEventListener('input', function() {
    document.getElementById('passwordError').textContent = "";
});

 function togglePassword() {
    const pass = document.getElementById("password");
    pass.type = pass.type === "password" ? "text" : "password";
}
 function validateLogin() {
    const email = document.getElementById('email').value.trim();
    if (!email) {
        
        Swal.fire('Error', 'Please enter email first', 'error'); 
        return false;
    }
    return true;
}
window.onpageshow = function(event) {
        if (event.persisted || (window.performance && window.performance.navigation.type === 2)) {
            window.location.reload();
        }
    };
</script>

</body>
</html>