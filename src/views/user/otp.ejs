<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verify Code | Authentication</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        /* Remove arrows from number inputs */
        input::-webkit-outer-spin-button,
        input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
    </style>
</head>
<body class="bg-gray-50 flex items-center justify-center min-h-screen p-4">

    <div class="bg-white p-8 md:p-10 rounded-2xl shadow-xl w-full max-w-md border border-gray-100 text-center">
        
        <div class="flex justify-center mb-4">
            <div class="bg-black p-2.5 rounded-lg shadow-md">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>
        </div>

        <h1 class="text-3xl font-bold text-gray-900 mb-2">Verify Your Email</h1>
        <p class="text-gray-500 text-sm mb-8 leading-relaxed">
            Enter the 6-digit code sent to <span class="font-semibold text-gray-800"><%= locals.email || 'your email' %></span>
        </p>

        <% if (locals.error) { %>
            <div id="errorMessage" class="mb-6 p-3 bg-red-50 border-l-4 border-red-500 text-red-700 text-xs rounded font-semibold">
                <%= error %>
            </div>
        <% } %>

        
      <form id="otpForm">
           
<div class="flex justify-between gap-2 md:gap-4" id="otpInputs">
    <input type="number" class="otp-input w-12 h-14 text-center text-xl font-bold bg-gray-200 border-2 border-transparent rounded-xl focus:bg-white focus:ring-2 focus:ring-yellow-600 outline-none transition-all" required>
    <input type="number" class="otp-input w-12 h-14 text-center text-xl font-bold bg-gray-200 border-2 border-transparent rounded-xl focus:bg-white focus:ring-2 focus:ring-yellow-600 outline-none transition-all" required>
    <input type="number" class="otp-input w-12 h-14 text-center text-xl font-bold bg-gray-200 border-2 border-transparent rounded-xl focus:bg-white focus:ring-2 focus:ring-yellow-600 outline-none transition-all" required>
    <input type="number" class="otp-input w-12 h-14 text-center text-xl font-bold bg-gray-200 border-2 border-transparent rounded-xl focus:bg-white focus:ring-2 focus:ring-yellow-600 outline-none transition-all" required>
    <input type="number" class="otp-input w-12 h-14 text-center text-xl font-bold bg-gray-200 border-2 border-transparent rounded-xl focus:bg-white focus:ring-2 focus:ring-yellow-600 outline-none transition-all" required>
    <input type="number" class="otp-input w-12 h-14 text-center text-xl font-bold bg-gray-200 border-2 border-transparent rounded-xl focus:bg-white focus:ring-2 focus:ring-yellow-600 outline-none transition-all" required>
</div>

            <button type="submit" id="verifyBtn" 
                class="w-full mt-8 py-3 bg-[#c0943c] hover:bg-[#a67d2e] text-white font-bold rounded-full shadow-lg transform active:scale-95 transition-all">
                Verify code
            </button> 
           
        </form>

      <div class="mt-8 text-sm text-center">
    
    <p class="text-gray-600 mb-2">Didn't receive the code?</p>
    
    <button id="resendBtn" onclick="resendOTP()" 
            class="font-bold text-gray-400 transition-colors duration-300" disabled >
        Resend OTP
    </button>
    
    <div id="timer-display" class="text-sm text-[#B88E2F] mt-2 font-medium">
        Wait <span id="time">02:00</span>
    </div>
</div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

   

<script>
    const inputs = document.querySelectorAll('#otpInputs input');
    const verifyBtn = document.getElementById('verifyBtn');
    const resendBtn = document.getElementById('resendBtn');
    const timerDisplay = document.getElementById('timer-display');

    let timerInterval;
    let isTimerExpired = false;


    function startTimer(duration) {
        let timeLeft = duration;
        isTimerExpired = false;
        
        if (resendBtn) {
            resendBtn.disabled = true;
            resendBtn.classList.remove('text-gray-900', 'hover:underline');
            resendBtn.classList.add('text-gray-400', 'cursor-not-allowed');
            resendBtn.style.pointerEvents = 'none';
            resendBtn.style.color = ''; 
        }

        if (verifyBtn) {
            verifyBtn.disabled = false;
            verifyBtn.classList.remove('opacity-50', 'cursor-not-allowed');
        }

        clearInterval(timerInterval);
        
        const updateUI = () => {
            if (timerDisplay) {
                let minutes = Math.floor(timeLeft / 60);
                let seconds = timeLeft % 60;
                timerDisplay.innerHTML = `0${minutes}:${seconds < 10 ? '0' : ''}${seconds}`;
            }
        };

        updateUI();

        if (timeLeft <= 0) {
            isTimerExpired = true;
            if (resendBtn) {
                resendBtn.disabled = false;
                resendBtn.classList.remove('text-gray-400', 'cursor-not-allowed');
                resendBtn.classList.add('text-gray-900', 'hover:underline');
                resendBtn.style.pointerEvents = 'auto';
                resendBtn.style.color = '#B88E2F'; 
            }
            if (verifyBtn) {
                verifyBtn.disabled = true;
                verifyBtn.classList.add('opacity-50', 'cursor-not-allowed');
            }
            if (timerDisplay) timerDisplay.innerHTML = "00:00";
            return;
        }
        
        timerInterval = setInterval(() => {
            timeLeft--;
            updateUI();

            if (timeLeft <= 0) {
                clearInterval(timerInterval);
                isTimerExpired = true;
                
                if (resendBtn) {
                    resendBtn.disabled = false;
                    resendBtn.classList.remove('text-gray-400', 'cursor-not-allowed');
                    resendBtn.classList.add('text-gray-900', 'hover:underline');
                    resendBtn.style.pointerEvents = 'auto';
                    resendBtn.style.color = '#B88E2F'; 
                }
                if (verifyBtn) {
                    verifyBtn.disabled = true;
                    verifyBtn.classList.add('opacity-50', 'cursor-not-allowed');
                }
                if (timerDisplay) timerDisplay.innerHTML = "00:00";
            }
        }, 1000);
    }

    
    const initialTime = Number("<%= locals.remainingTime !== undefined ? remainingTime : 120 %>") || 120;
    startTimer(initialTime);

    
    inputs.forEach((input, index) => {
        input.addEventListener('input', (e) => {
            if (e.target.value.length > 1) e.target.value = e.target.value.slice(0, 1);
            if (e.target.value !== "" && index < inputs.length - 1) {
                inputs[index + 1].focus();
            }
        });
        input.addEventListener('keydown', (e) => {
            if (e.key === "Backspace" && e.target.value === "" && index > 0) {
                inputs[index - 1].focus();
            }
        });
    });

    // 
    async function resendOTP() {
        try {
            resendBtn.disabled = true;
            const response = await fetch('/resend-otp', { method: 'POST' });
            const data = await response.json();

            if (data.success) {
                Swal.fire({
                    icon: 'success',
                    title: 'OTP Sent!',
                    text: 'A new OTP has been sent to your email.',
                    timer: 1500,
                    showConfirmButton: false
                });
                startTimer(120); 
            } else {
                Swal.fire('Error', data.message, 'error');
                resendBtn.disabled = false;
            }
        } catch (error) {
            console.error('Error:', error);
            resendBtn.disabled = false;
        }
    }

    
    if (verifyBtn) {
        verifyBtn.addEventListener('click', async function(e) { 
            e.preventDefault();
            
            if (isTimerExpired) {
                Swal.fire('Expired', 'otp expired', 'error');
                return;
            }
            
            let otpValue = "";
            inputs.forEach(input => otpValue += input.value);

            if (otpValue.length < 6) {
                Swal.fire('Wait', 'Please enter the full 6-digit code.', 'warning');
                return;
            }

            verifyBtn.disabled = true;
            verifyBtn.innerText = "Verifying...";

            try {
                const response = await fetch('/verify-otp', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ otp: otpValue }) 
                });

                const data = await response.json();

                if (data.success) {
                    window.location.href = data.redirectUrl || '/';
                } else {
                    Swal.fire('Invalid', data.message, 'error');
                    verifyBtn.disabled = false;
                    verifyBtn.innerText = "Verify code";
                }
            } catch (err) {
                console.error("Error:", err);
                Swal.fire('Error', 'Something went wrong.', 'error');
                verifyBtn.disabled = false;
                verifyBtn.innerText = "Verify code";
            }
        });
    }
</script>
</body>
</html>