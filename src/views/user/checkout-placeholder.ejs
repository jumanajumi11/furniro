<%- include('../layout/header') %>

<main class="bg-white min-h-screen">
  <%/* ── Top Hero Banner ─────────────────────────────────────────── */%>
  <section class="relative w-full h-[250px] flex items-center justify-center overflow-hidden bg-cover bg-center"
           style="background-image: linear-gradient(rgba(255,255,255,0.7), rgba(255,255,255,0.7)), url('https://images.unsplash.com/photo-1540518614846-7eded433c457?auto=format&fit=crop&w=1920&q=80');">
    <div class="text-center relative z-10">
      <div class="flex justify-center mb-3">
        <img src="https://res.cloudinary.com/dp9odkfmd/image/upload/v1777118568/Meubel_House_Logos-05_uklcwh.png" alt="Logo" class="h-10 w-10 object-contain">
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-2">Checkout</h1>
      <p class="text-sm font-semibold tracking-wider text-gray-600 uppercase">
        <a href="/cart" class="hover:text-[#B88E2F] transition-colors">Cart</a>
        <span class="mx-2 text-gray-400">&gt;</span>
        <span class="text-[#B88E2F]">Checkout</span>
      </p>
    </div>
  </section>

  <%/* ── Checkout Details ────────────────────────────────────────── */%>
  <section class="max-w-4xl mx-auto px-6 py-16 text-center">
    <div class="bg-green-50 border border-green-200 rounded-2xl p-8 max-w-xl mx-auto mb-10">
      <div class="text-green-500 text-5xl mb-4">
        <i class="fas fa-check-circle"></i>
      </div>
      <h2 class="text-2xl font-bold text-gray-800 mb-2">Cart Validated Successfully!</h2>
      <p class="text-gray-600 text-sm">
        All items are in stock and ready. You are good to proceed with the purchase.
      </p>
    </div>

    <div class="bg-gray-50 border border-gray-100 rounded-2xl p-8 max-w-xl mx-auto text-left space-y-6">
      <h3 class="font-bold text-lg text-gray-900 border-b border-gray-200 pb-3">Order Summary</h3>
      
      <div class="space-y-4">
        <% items.forEach(item => { %>
          <%
            let size = '';
            let color = '';
            let price = item.productId.salePrice || item.productId.regularPrice || 0;
            if (item.productId.variants && item.productId.variants.length > 0 && item.variantId) {
                const variant = item.productId.variants.id(item.variantId);
                if (variant) {
                    size = variant.size;
                    color = variant.color;
                    price = variant.price || price;
                }
            }
          %>
          <div class="flex justify-between items-center text-sm text-gray-700">
            <div>
              <span class="font-semibold text-gray-900"><%= item.productId.productName %></span>
              <% if (size || color) { %>
                <span class="text-xs text-gray-500 font-medium">(<%= [size, color].filter(Boolean).join(', ') %>)</span>
              <% } %>
              <span class="text-xs text-gray-400 font-bold ml-1">x<%= item.quantity %></span>
            </div>
            <span class="font-medium text-gray-900"><%= formatCurrency(price * item.quantity) %></span>
          </div>
        <% }) %>
      </div>

      <hr class="border-gray-200">

      <div class="space-y-3">
        <div class="flex justify-between text-sm text-gray-600">
          <span>Subtotal</span>
          <span class="font-semibold text-gray-900"><%= formatCurrency(totals.subtotal) %></span>
        </div>
        <% if (totals.discount > 0) { %>
          <div class="flex justify-between text-sm text-green-600">
            <span>Discount</span>
            <span class="font-semibold">-<%= formatCurrency(totals.discount) %></span>
          </div>
        <% } %>
        <div class="flex justify-between text-sm text-gray-600">
          <span>VAT (10%)</span>
          <span class="font-semibold text-gray-900"><%= formatCurrency(totals.tax) %></span>
        </div>
        <div class="flex justify-between text-sm text-gray-600">
          <span>Shipping Charge</span>
          <span class="font-semibold text-gray-900">
            <%= totals.shippingCharge === 0 ? 'Free' : formatCurrency(totals.shippingCharge) %>
          </span>
        </div>
        
        <hr class="border-gray-200/50">

        <div class="flex justify-between items-end">
          <span class="font-bold text-gray-900 text-base">Grand Total</span>
          <span class="text-xl font-extrabold text-[#B88E2F]"><%= formatCurrency(totals.grandTotal) %></span>
        </div>
      </div>
    </div>

    <div class="mt-8 flex justify-center gap-4">
      <a href="/cart" class="border border-gray-300 text-gray-700 px-6 py-2.5 rounded-lg text-sm font-bold hover:bg-gray-50 transition-all">
        Back to Cart
      </a>
      <button onclick="placeOrderPlaceholder()" class="bg-[#B88E2F] hover:bg-[#967325] text-white px-8 py-2.5 rounded-lg text-sm font-bold shadow-md transition-all">
        Place Order
      </button>
    </div>
  </section>
</main>

<script>
  function placeOrderPlaceholder() {
      Swal.fire({
          icon: 'success',
          title: 'Order Placed!',
          text: 'Thank you for your purchase. This is a mockup checkout page completion.',
          confirmButtonColor: '#B88E2F'
      }).then(() => {
          window.location.href = '/shop';
      });
  }
</script>

<%- include('../layout/footer') %>
