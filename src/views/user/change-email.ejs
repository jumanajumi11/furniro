<%- include('../layout/header') %>
<body class="text-gray-800">
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="flex flex-col lg:flex-row gap-8">
            <%- include('../layout/account-sidebar', { activePage: 'profile' }) %>

            <div class="flex-1 bg-white rounded-2xl shadow-sm border border-gray-100">
                <div class="p-8 border-b border-gray-100 flex justify-between items-center">
                    <div>
                        <h2 class="text-xl font-bold text-gray-900">Change Email Address</h2>
                        <p class="text-xs text-gray-500 mt-1">We will send a verification code to your new email address.</p>
                    </div>
                    <a href="/profile/edit" class="text-gray-400 hover:text-[#B88E2F] text-sm font-medium">Back to Edit Profile</a>
                </div>

                <div class="p-8 max-w-xl">
                    <% if (error) { %>
                        <div class="bg-red-50 border-l-4 border-red-500 text-red-700 p-4 rounded-lg mb-6 text-sm flex items-center gap-2">
                            <i class="fas fa-exclamation-circle text-red-500"></i>
                            <span><%= error %></span>
                        </div>
                    <% } %>

                    <form action="/profile/change-email" method="POST" class="space-y-6">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Current Email Address</label>
                            <input type="text" value="<%= user.email %>" readonly class="w-full px-4 py-3 border border-gray-200 rounded-lg bg-gray-50 text-gray-400 cursor-not-allowed outline-none">
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">New Email Address</label>
                            <input type="email" name="email" value="<%= emailValue %>" required placeholder="new-email@example.com" class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-[#B88E2F] outline-none transition-all">
                        </div>

                        <div class="pt-4 flex gap-4">
                            <button type="submit" class="bg-[#B88E2F] hover:bg-[#A07B28] text-white px-8 py-3 rounded-lg font-medium shadow-md transition-all">
                                Send Verification Code
                            </button>
                            <a href="/profile/edit" class="border border-gray-200 hover:bg-gray-50 text-gray-600 px-8 py-3 rounded-lg font-medium transition-all text-center">
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </main>
</body>
</html>
