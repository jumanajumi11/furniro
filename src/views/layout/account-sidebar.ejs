<% const page = typeof activePage !== 'undefined' ? activePage : ''; %>
<aside class="w-full lg:w-72 bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden py-6 px-4 h-fit flex-shrink-0">
    <nav class="flex flex-col text-sm font-medium">
        <a href="/profile" class="flex items-center gap-4 px-6 py-3.5 <%= page === 'profile' ? 'bg-[#FCF9F4] text-[#B88E2F] border-l-4 border-[#B88E2F]' : 'text-gray-600 hover:bg-gray-50 hover:text-[#B88E2F] border-l-4 border-transparent transition-colors' %>">
            <i class="far fa-user text-lg w-5 text-center"></i>
            Profile Information
        </a>
        <a href="/addresses" class="flex items-center gap-4 px-6 py-3.5 <%= page === 'addresses' ? 'bg-[#FCF9F4] text-[#B88E2F] border-l-4 border-[#B88E2F]' : 'text-gray-600 hover:bg-gray-50 hover:text-[#B88E2F] border-l-4 border-transparent transition-colors' %>">
            <i class="fas fa-map-marker-alt text-lg w-5 text-center"></i>
            My Addresses
        </a>
        <a href="/orders" class="flex items-center gap-4 px-6 py-3.5 <%= page === 'orders' ? 'bg-[#FCF9F4] text-[#B88E2F] border-l-4 border-[#B88E2F]' : 'text-gray-600 hover:bg-gray-50 hover:text-[#B88E2F] border-l-4 border-transparent transition-colors' %>">
            <i class="fas fa-box text-lg w-5 text-center"></i>
            My Orders
        </a>
        <a href="/wishlist" class="flex items-center gap-4 px-6 py-3.5 <%= page === 'wishlist' ? 'bg-[#FCF9F4] text-[#B88E2F] border-l-4 border-[#B88E2F]' : 'text-gray-600 hover:bg-gray-50 hover:text-[#B88E2F] border-l-4 border-transparent transition-colors' %>">
            <i class="far fa-heart text-lg w-5 text-center"></i>
            My Wishlist
        </a>
        <a href="/wallet" class="flex items-center gap-4 px-6 py-3.5 <%= page === 'wallet' ? 'bg-[#FCF9F4] text-[#B88E2F] border-l-4 border-[#B88E2F]' : 'text-gray-600 hover:bg-gray-50 hover:text-[#B88E2F] border-l-4 border-transparent transition-colors' %>">
            <i class="fas fa-wallet text-lg w-5 text-center"></i>
            My Wallet
        </a>
        <a href="/coupons" class="flex items-center gap-4 px-6 py-3.5 <%= page === 'coupons' ? 'bg-[#FCF9F4] text-[#B88E2F] border-l-4 border-[#B88E2F]' : 'text-gray-600 hover:bg-gray-50 hover:text-[#B88E2F] border-l-4 border-transparent transition-colors' %>">
            <i class="fas fa-ticket-alt text-lg w-5 text-center"></i>
            Coupons
        </a>
        <a href="/referrals" class="flex items-center gap-4 px-6 py-3.5 <%= page === 'referrals' ? 'bg-[#FCF9F4] text-[#B88E2F] border-l-4 border-[#B88E2F]' : 'text-gray-600 hover:bg-gray-50 hover:text-[#B88E2F] border-l-4 border-transparent transition-colors' %>">
            <i class="fas fa-user-friends text-lg w-5 text-center"></i>
            Referrals
        </a>
        <a href="/security" class="flex items-center gap-4 px-6 py-3.5 <%= page === 'security' ? 'bg-[#FCF9F4] text-[#B88E2F] border-l-4 border-[#B88E2F]' : 'text-gray-600 hover:bg-gray-50 hover:text-[#B88E2F] border-l-4 border-transparent transition-colors' %>">
            <i class="fas fa-shield-alt text-lg w-5 text-center"></i>
            Security Settings
        </a>
    </nav>
</aside>
