<!-- src/views/admin/adminPartials/adminSidebar.ejs -->
<%
  const page = locals.activePage || '';
  const activeClass = "flex items-center gap-3 px-4 py-3 bg-[#B88E2F]/10 border-l-4 border-[#B88E2F] text-[#B88E2F] rounded-r-xl font-bold text-sm transition-all";
  const inactiveClass = "flex items-center gap-3 px-4 py-3 text-gray-500 hover:text-gray-900 hover:bg-gray-50/50 rounded-xl font-medium transition-all";
%>
<aside class="w-64 bg-white border-r border-gray-100 flex flex-col sticky top-0 h-screen shrink-0 shadow-sm z-30">
    <!-- Brand Logo -->
    <div class="h-20 flex items-center px-8 shrink-0 border-b border-gray-50">
        <div class="flex items-center gap-2.5">
            <div class="w-9 h-9 bg-[#B88E2F] rounded-xl flex items-center justify-center shadow-lg shadow-[#B88E2F]/10">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V9z" />
                </svg>
            </div>
            <span class="text-2xl font-black text-gray-900 tracking-tight">Furniro</span>
        </div>
    </div>

    <!-- Navigation Area -->
    <div class="flex-1 overflow-y-auto py-6 px-4 space-y-7 sidebar-scroll">
        <!-- Overview Section -->
        <div>
            <p class="px-4 text-[10px] font-black text-gray-400 uppercase tracking-widest mb-3">Overview</p>
            <nav class="space-y-1">
                <a href="/admin/dashboard" class="<%= page === 'dashboard' ? activeClass : inactiveClass %>">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
                    </svg>
                    <span>Dashboard</span>
                </a>
                <a href="#" class="<%= page === 'analytics' ? activeClass : inactiveClass %>">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                    </svg>
                    <span>Analytics</span>
                </a>
            </nav>
        </div>

        <!-- Management Section -->
        <div>
            <p class="px-4 text-[10px] font-black text-gray-400 uppercase tracking-widest mb-3">Management</p>
            <nav class="space-y-1">
                <a href="/admin/products" class="<%= page === 'products' ? activeClass : inactiveClass %>">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                    </svg>
                    <span>Products</span>
                </a>
                <a href="/admin/categories" class="<%= page === 'categories' ? activeClass : inactiveClass %>">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
                    </svg>
                    <span>Categories</span>
                </a>
                <a href="/admin/orders" class="<%= page === 'orders' ? activeClass : inactiveClass %>">
                    <div class="flex items-center justify-between w-full">
                        <div class="flex items-center gap-3">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                            </svg>
                            <span>Orders</span>
                        </div>
                        <span class="bg-green-50 text-green-600 py-0.5 px-2 rounded-full text-[10px] font-black">12</span>
                    </div>
                </a>
                <a href="/admin/customers" class="<%= page === 'customers' ? activeClass : inactiveClass %>">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                    </svg>
                    <span>Customers</span>
                </a>
                <a href="/admin/coupons" class="<%= page === 'coupons' ? activeClass : inactiveClass %>">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />
                    </svg>
                    <span>Coupons</span>
                </a>
                <a href="/admin/banners" class="<%= page === 'banners' ? activeClass : inactiveClass %>">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                    <span>Banners</span>
                </a>
                <a href="/admin/discount" class="<%= page === 'discount' ? activeClass : inactiveClass %>">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span>Discount</span>
                </a>
            </nav>
        </div>

        <!-- Settings Section -->
        <div>
            <p class="px-4 text-[10px] font-black text-gray-400 uppercase tracking-widest mb-3">Settings</p>
            <nav class="space-y-1">
                <a href="/admin/settings" class="<%= page === 'settings' ? activeClass : inactiveClass %>">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                    <span>General</span>
                </a>
            </nav>
        </div>
    </div>

    <!-- Bottom Actions / Logout -->
    <div class="p-4 border-t border-gray-50">
        <a href="/admin/logout" class="flex items-center gap-3 px-4 py-3 text-red-500 hover:bg-red-50 rounded-xl font-bold text-sm transition-all">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
            </svg>
            <span>Log Out</span>
        </a>
    </div>
</aside>
