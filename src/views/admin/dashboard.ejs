<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - Furniro</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: #F9FAFB; }
    </style>
</head>
<body class="flex h-screen overflow-hidden text-gray-800 bg-[#F9FAFB]">

    <!-- Sidebar -->
    <%- include('./adminPartials/adminSidebar.ejs', { activePage: 'dashboard' }) %>

    <!-- Main Content -->
    <main class="flex-1 flex flex-col h-full overflow-hidden relative">
        
        <!-- Header -->
        <header class="bg-white border-b border-gray-100 px-6 lg:px-8 h-16 flex items-center justify-between shrink-0 z-20 shadow-sm">
            <div>
                <h1 class="text-xl font-extrabold text-gray-900 tracking-tight">DASHBOARD</h1>
            </div>
            
            <div class="flex items-center gap-3">
                <div class="text-right">
                    <p class="text-xs font-black text-[#B88E2F] uppercase tracking-widest leading-none">System Admin</p>
                    <p class="text-xs font-bold text-gray-800 mt-1">Jumana</p>
                </div>
                <div class="w-9 h-9 rounded-xl bg-[#B88E2F] flex items-center justify-center text-white font-black text-sm shadow">
                    JU
                </div>
            </div>
        </header>

        <!-- Content Area -->
        <div class="flex-1 overflow-y-auto p-6 lg:p-8 space-y-8">
            <div class="max-w-[1400px] mx-auto w-full">
                
                <!-- Stat Cards -->
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                    <!-- Revenue Card -->
                    <div class="bg-white rounded-[20px] p-6 border border-gray-100 shadow-sm">
                        <div class="flex justify-between items-start mb-4">
                            <div>
                                <p class="text-xs font-black text-gray-400 uppercase tracking-widest mb-1">Total Revenue</p>
                                <h3 class="text-2xl font-black text-gray-900 tracking-tight">₹<%= totalRevenue.toLocaleString('en-IN') %></h3>
                            </div>
                            <div class="w-12 h-12 rounded-2xl bg-[#E8F8F0] flex items-center justify-center text-[#21A366]">
                                <i class="fas fa-wallet text-lg"></i>
                            </div>
                        </div>
                        <span class="block text-[10px] text-gray-400 font-semibold">Net earnings from orders</span>
                    </div>

                    <!-- Orders Card -->
                    <div class="bg-white rounded-[20px] p-6 border border-gray-100 shadow-sm">
                        <div class="flex justify-between items-start mb-4">
                            <div>
                                <p class="text-xs font-black text-gray-400 uppercase tracking-widest mb-1">Total Orders</p>
                                <h3 class="text-2xl font-black text-gray-900 tracking-tight"><%= totalOrders %></h3>
                            </div>
                            <div class="w-12 h-12 rounded-2xl bg-blue-50 flex items-center justify-center text-blue-600">
                                <i class="fas fa-shopping-bag text-lg"></i>
                            </div>
                        </div>
                        <span class="block text-[10px] text-gray-400 font-semibold">Total checkout sales</span>
                    </div>

                    <!-- Users Card -->
                    <div class="bg-white rounded-[20px] p-6 border border-gray-100 shadow-sm">
                        <div class="flex justify-between items-start mb-4">
                            <div>
                                <p class="text-xs font-black text-gray-400 uppercase tracking-widest mb-1">Total Users</p>
                                <h3 class="text-2xl font-black text-gray-900 tracking-tight"><%= totalUsers %></h3>
                            </div>
                            <div class="w-12 h-12 rounded-2xl bg-orange-50 flex items-center justify-center text-orange-500">
                                <i class="fas fa-users text-lg"></i>
                            </div>
                        </div>
                        <span class="block text-[10px] text-gray-400 font-semibold">Registered customers</span>
                    </div>

                    <!-- Products Card -->
                    <div class="bg-white rounded-[20px] p-6 border border-gray-100 shadow-sm">
                        <div class="flex justify-between items-start mb-4">
                            <div>
                                <p class="text-xs font-black text-gray-400 uppercase tracking-widest mb-1">Total Products</p>
                                <h3 class="text-2xl font-black text-gray-900 tracking-tight"><%= totalProducts %></h3>
                            </div>
                            <div class="w-12 h-12 rounded-2xl bg-purple-50 flex items-center justify-center text-purple-600">
                                <i class="fas fa-chair text-lg"></i>
                            </div>
                        </div>
                        <span class="block text-[10px] text-gray-400 font-semibold">Inventory item listings</span>
                    </div>
                </div>

                <!-- Main Grid Layout -->
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mt-8">
                    
                    <!-- Sales Chart (Spans 2 columns) -->
                    <div class="lg:col-span-2 bg-white border border-gray-100 rounded-3xl p-6 shadow-sm flex flex-col justify-between">
                        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6">
                            <div>
                                <h2 class="text-base font-extrabold text-gray-900">Performance Trends</h2>
                                <p class="text-xs text-gray-400 font-medium">Select chart type and filter to plot database trends.</p>
                            </div>
                            
                            <div class="flex items-center gap-2 self-end sm:self-auto">
                                <select id="chartMetric" onchange="renderChart()"
                                        class="bg-gray-50 border border-gray-100 text-gray-700 text-xs font-bold rounded-xl block py-2 px-3 outline-none cursor-pointer">
                                    <option value="revenue" selected>Revenue Trend (₹)</option>
                                    <option value="sales">Sales Trend (Qty Sold)</option>
                                    <option value="orders">Orders Trend (Count)</option>
                                </select>
                                
                                <select id="chartFilter" onchange="fetchChartData()"
                                        class="bg-gray-50 border border-gray-100 text-gray-700 text-xs font-bold rounded-xl block py-2 px-3 outline-none cursor-pointer">
                                    <option value="Daily">Daily</option>
                                    <option value="Weekly">Weekly</option>
                                    <option value="Monthly" selected>Monthly</option>
                                    <option value="Yearly">Yearly</option>
                                </select>
                            </div>
                        </div>
                        <div class="h-[300px] w-full relative">
                            <canvas id="dashboardChart"></canvas>
                        </div>
                    </div>

                    <!-- Order Fulfillment Status -->
                    <div class="bg-white border border-gray-100 rounded-3xl p-6 shadow-sm flex flex-col justify-between">
                        <div>
                            <h2 class="text-base font-extrabold text-gray-900 mb-1">Fulfillment Status</h2>
                            <p class="text-xs text-gray-400 font-medium mb-8">Summary of order fulfillment counts</p>
                        </div>

                        <div class="space-y-6 flex-1">
                            <!-- Delivered -->
                            <div>
                                <% const delPercent = Math.round((statusCounts.delivered / (statusCounts.total || 1)) * 100); %>
                                <div class="flex justify-between items-center mb-2">
                                    <span class="text-xs font-black text-gray-900">Delivered</span>
                                    <span class="text-xs font-black text-green-600"><%= delPercent %>%</span>
                                </div>
                                <div class="w-full bg-gray-100 rounded-full h-[6px] mb-1">
                                    <div class="bg-green-500 h-[6px] rounded-full" data-pct="<%= delPercent %>"></div>
                                </div>
                                <div class="text-right text-[10px] text-gray-400 font-bold"><%= statusCounts.delivered %> Orders</div>
                            </div>

                            <!-- Pending -->
                            <div>
                                <% const penPercent = Math.round((statusCounts.pending / (statusCounts.total || 1)) * 100); %>
                                <div class="flex justify-between items-center mb-2">
                                    <span class="text-xs font-black text-gray-900">Pending</span>
                                    <span class="text-xs font-black text-amber-500"><%= penPercent %>%</span>
                                </div>
                                <div class="w-full bg-gray-100 rounded-full h-[6px] mb-1">
                                    <div class="bg-amber-500 h-[6px] rounded-full" data-pct="<%= penPercent %>"></div>
                                </div>
                                <div class="text-right text-[10px] text-gray-400 font-bold"><%= statusCounts.pending %> Orders</div>
                            </div>

                            <!-- Cancelled -->
                            <div>
                                <% const canPercent = Math.round((statusCounts.cancelled / (statusCounts.total || 1)) * 100); %>
                                <div class="flex justify-between items-center mb-2">
                                    <span class="text-xs font-black text-gray-900">Cancelled</span>
                                    <span class="text-xs font-black text-red-500"><%= canPercent %>%</span>
                                </div>
                                <div class="w-full bg-gray-100 rounded-full h-[6px] mb-1">
                                    <div class="bg-red-500 h-[6px] rounded-full" data-pct="<%= canPercent %>"></div>
                                </div>
                                <div class="text-right text-[10px] text-gray-400 font-bold"><%= statusCounts.cancelled %> Orders</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- TOP SELLING ANALYTICS (Products, Categories, Brands) -->
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mt-8">
                    <!-- Top Products -->
                    <div class="bg-white border border-gray-100 rounded-3xl p-6 shadow-sm">
                        <h3 class="text-sm font-black text-gray-400 uppercase tracking-widest mb-4">Top 10 Products</h3>
                        <div class="space-y-4">
                            <% if (topProducts && topProducts.length > 0) { %>
                                <% topProducts.forEach((item, idx) => { %>
                                    <div class="flex items-center justify-between">
                                        <div class="flex items-center gap-2">
                                            <span class="text-xs font-black text-gray-400 w-5"><%= idx + 1 %>.</span>
                                            <span class="text-xs font-bold text-gray-800 truncate max-w-[150px]">
                                                <%= item.product ? item.product.productName : 'Product ID ' + item._id %>
                                            </span>
                                        </div>
                                        <div class="text-right">
                                            <span class="text-[10px] font-black text-[#B88E2F] block"><%= item.quantitySold %> Sold</span>
                                            <span class="text-[9px] text-gray-400 font-semibold">₹<%= item.revenue.toLocaleString('en-IN') %></span>
                                        </div>
                                    </div>
                                <% }) %>
                            <% } else { %>
                                <p class="text-xs text-gray-400 italic">No sales recorded.</p>
                            <% } %>
                        </div>
                    </div>

                    <!-- Top Categories -->
                    <div class="bg-white border border-gray-100 rounded-3xl p-6 shadow-sm">
                        <h3 class="text-sm font-black text-gray-400 uppercase tracking-widest mb-4">Top 10 Categories</h3>
                        <div class="space-y-4">
                            <% if (topCategories && topCategories.length > 0) { %>
                                <% topCategories.forEach((item, idx) => { %>
                                    <div class="flex items-center justify-between">
                                        <div class="flex items-center gap-2">
                                            <span class="text-xs font-black text-gray-400 w-5"><%= idx + 1 %>.</span>
                                            <span class="text-xs font-bold text-gray-800">
                                                <%= item.category ? item.category.name : 'Category ID ' + item._id %>
                                            </span>
                                        </div>
                                        <div class="text-right">
                                            <span class="text-[10px] font-black text-[#B88E2F] block"><%= item.quantitySold %> Sold</span>
                                            <span class="text-[9px] text-gray-400 font-semibold">₹<%= item.revenue.toLocaleString('en-IN') %></span>
                                        </div>
                                    </div>
                                <% }) %>
                            <% } else { %>
                                <p class="text-xs text-gray-400 italic">No sales recorded.</p>
                            <% } %>
                        </div>
                    </div>

                    <!-- Top Brands -->
                    <div class="bg-white border border-gray-100 rounded-3xl p-6 shadow-sm">
                        <h3 class="text-sm font-black text-gray-400 uppercase tracking-widest mb-4">Top 10 Brands</h3>
                        <div class="space-y-4">
                            <% if (topBrands && topBrands.length > 0) { %>
                                <% topBrands.forEach((item, idx) => { %>
                                    <div class="flex items-center justify-between">
                                        <div class="flex items-center gap-2">
                                            <span class="text-xs font-black text-gray-400 w-5"><%= idx + 1 %>.</span>
                                            <span class="text-xs font-bold text-gray-800"><%= item._id %></span>
                                        </div>
                                        <div class="text-right">
                                            <span class="text-[10px] font-black text-[#B88E2F] block"><%= item.quantitySold %> Sold</span>
                                            <span class="text-[9px] text-gray-400 font-semibold">₹<%= item.revenue.toLocaleString('en-IN') %></span>
                                        </div>
                                    </div>
                                <% }) %>
                            <% } else { %>
                                <p class="text-xs text-gray-400 italic">No sales recorded.</p>
                            <% } %>
                        </div>
                    </div>
                </div>

                <!-- Recent Orders Table -->
                <div class="bg-white border border-gray-100 rounded-3xl shadow-sm overflow-hidden mt-8 mb-4">
                    <div class="p-6 border-b border-gray-100 flex justify-between items-center">
                        <div>
                            <h2 class="text-base font-extrabold text-gray-900">Recent Orders</h2>
                            <p class="text-xs text-gray-400 font-medium mt-1">Manage and track recent purchases</p>
                        </div>
                        <a href="/admin/orders" class="text-xs font-bold text-gray-500 hover:text-gray-900 flex items-center gap-1">
                            View All <i class="fas fa-chevron-right text-[10px]"></i>
                        </a>
                    </div>
                    <div class="overflow-x-auto w-full">
                        <table class="w-full text-sm text-left">
                            <thead class="text-xs text-gray-700 bg-white uppercase border-b border-gray-100">
                                <tr>
                                    <th scope="col" class="px-6 py-4 font-bold tracking-wider">Order ID</th>
                                    <th scope="col" class="px-6 py-4 font-bold tracking-wider">Customer</th>
                                    <th scope="col" class="px-6 py-4 font-bold tracking-wider">Product Info</th>
                                    <th scope="col" class="px-6 py-4 font-bold tracking-wider">Amount</th>
                                    <th scope="col" class="px-6 py-4 class text-center">Status</th>
                                    <th scope="col" class="px-6 py-4 text-center">Actions</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-100">
                                <% if (recentOrders && recentOrders.length > 0) { %>
                                    <% recentOrders.forEach(order => { %>
                                        <tr class="hover:bg-gray-50/50 transition-colors">
                                            <td class="px-6 py-4 font-semibold text-gray-600 text-xs">
                                                <%= order.orderNumber || order._id %>
                                            </td>
                                            <td class="px-6 py-4 font-bold text-gray-900 text-xs">
                                                <%= order.userId ? order.userId.name : (order.shippingAddress ? order.shippingAddress.name : 'Guest User') %>
                                            </td>
                                            <td class="px-6 py-4 font-medium text-gray-600 text-xs">
                                                <%= order.items && order.items.length > 0 && order.items[0].productId ? order.items[0].productId.productName : 'Furniture Item' %>
                                                <%= order.items && order.items.length > 1 ? ` (+${order.items.length - 1} more)` : '' %>
                                            </td>
                                            <td class="px-6 py-4 font-bold text-gray-900 text-xs">
                                                ₹<%= order.grandTotal.toLocaleString('en-IN') %>
                                            </td>
                                            <td class="px-6 py-4 text-center">
                                                <span class="py-1 px-3 rounded text-[10px] font-bold bg-[#E8F8F0] text-[#21A366]">
                                                    <%= order.status %>
                                                </span>
                                            </td>
                                            <td class="px-6 py-4 text-center">
                                                <a href="/admin/orders/<%= order._id %>" class="text-gray-400 hover:text-gray-600">
                                                    <i class="fas fa-eye text-xs"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="6" class="py-10 text-center text-gray-400 italic">No orders logged.</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script>
        let myChart = null;
        let chartData = null;

        document.addEventListener('DOMContentLoaded', function() {
            fetchChartData();
        });

        async function fetchChartData() {
            const filter = document.getElementById('chartFilter').value;
            try {
                const response = await fetch(`/admin/api/dashboard-stats?filter=${filter}`);
                const data = await response.json();

                if (data.success) {
                    chartData = data;
                    renderChart();
                }
            } catch (err) {
                console.error('Error fetching dashboard stats:', err);
            }
        }

        function renderChart() {
            if (!chartData) return;

            const metric = document.getElementById('chartMetric').value;
            const ctx = document.getElementById('dashboardChart').getContext('2d');

            let datasetLabel = '';
            let dataPoints = [];
            let borderCol = '#4ADE80';
            let bgCol = 'rgba(74, 222, 128, 0.2)';

            if (metric === 'revenue') {
                datasetLabel = 'Revenue (₹)';
                dataPoints = chartData.revenueTrend;
                borderCol = '#B88E2F';
                bgCol = 'rgba(184, 142, 47, 0.1)';
            } else if (metric === 'sales') {
                datasetLabel = 'Sales Count (Qty Sold)';
                dataPoints = chartData.salesTrend;
                borderCol = '#3B82F6';
                bgCol = 'rgba(59, 130, 246, 0.1)';
            } else {
                datasetLabel = 'Orders Count';
                dataPoints = chartData.orderTrend;
                borderCol = '#A855F7';
                bgCol = 'rgba(168, 85, 247, 0.1)';
            }

            if (myChart) {
                myChart.destroy();
            }

            let gradient = ctx.createLinearGradient(0, 0, 0, 300);
            gradient.addColorStop(0, bgCol);
            gradient.addColorStop(1, 'rgba(255, 255, 255, 0)');

            myChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: chartData.labels,
                    datasets: [{
                        label: datasetLabel,
                        data: dataPoints,
                        borderColor: borderCol,
                        backgroundColor: gradient,
                        borderWidth: 3,
                        pointBackgroundColor: '#ffffff',
                        pointBorderColor: borderCol,
                        pointBorderWidth: 2,
                        pointRadius: 4,
                        pointHoverRadius: 6,
                        fill: true,
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: { color: '#F3F4F6', drawBorder: false }
                        },
                        x: {
                            grid: { display: false }
                        }
                    }
                }
            });
        }
        document.querySelectorAll('[data-pct]').forEach(function(el) {
            el.style.width = el.getAttribute('data-pct') + '%';
        });
    </script>
</body>
</html>
