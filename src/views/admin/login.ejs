<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Furniro - Admin Login</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background-color: #FFFFFF;
        }
        /* Custom scrollbar for better aesthetics if needed */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #f1f1f1; }
        ::-webkit-scrollbar-thumb { background: #B88E2F; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #a37d28; }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center bg-white p-4">

    <!-- Admin Login Card -->
    <!-- Matches the 1400x996 vibe by being centered in a full viewport -->
    <div class="w-full max-w-[500px] bg-white rounded-[24px] shadow-[0_8px_40px_rgba(0,0,0,0.08)] border border-gray-100 px-10 py-14 flex flex-col relative">
        
        <!-- Header Section -->
        <div class="flex flex-col items-center mb-10">
            <div class="flex items-center gap-3 mb-4">
                <img src="https://res.cloudinary.com/dp9odkfmd/image/upload/v1777118568/Meubel_House_Logos-05_uklcwh.png" alt="Furniro Logo" class="h-10 w-10 object-contain">
                <span class="text-[32px] font-bold text-black tracking-tight">Furniro</span>
            </div>
            <h1 class="text-[26px] font-bold text-black mb-1">Admin Login</h1>
            <p class="text-[14px] text-[#A3A3A3]">Sign into manage your store</p>
        </div>

        <!-- Form Section -->
        <form action="/admin/login" method="POST" class="w-full flex flex-col gap-6">
            
            <!-- Dynamic Error Message -->
            <% if (typeof error !== 'undefined' && error) { %>
                <div class="bg-red-50 text-red-500 text-sm px-4 py-3 rounded-full border border-red-100 text-center font-medium animate-pulse">
                    <%= error %>
                </div>
            <% } %>

            <!-- Email Address Field -->
            <div class="flex flex-col gap-2">
                <label class="text-[14px] font-medium text-[#333333] ml-2">Email Address</label>
                <input type="email" name="email" placeholder="admin@Furniro.com" required
                    class="w-full h-[54px] px-6 bg-[#EBEBEB] rounded-full text-[15px] text-gray-800 placeholder-[#999999] shadow-inner focus:outline-none focus:ring-2 focus:ring-[#B88E2F] focus:bg-white transition-all border border-transparent focus:border-[#B88E2F]">
            </div>

            <!-- Forgot Password Link -->
            <div class="flex justify-end -mt-3 mb-0">
                <a href="/admin/forgot-password">Forgot Password?</a>
            </div>

            <!-- Password Field -->
            <div class="flex flex-col gap-2">
                <label class="text-[14px] font-medium text-[#333333] ml-2">Password</label>
                <input type="password" name="password" required
                    class="w-full h-[54px] px-6 bg-[#EBEBEB] rounded-full text-[15px] text-gray-800 shadow-inner focus:outline-none focus:ring-2 focus:ring-[#B88E2F] focus:bg-white transition-all border border-transparent focus:border-[#B88E2F]">
            </div>

            <!-- Log In Button -->
            <button type="submit" 
                class="w-full h-[56px] mt-4 bg-[#B88E2F] text-white text-[16px] font-semibold rounded-full hover:bg-[#a37d28] transition-all duration-300 shadow-[0_4px_15px_rgba(184,142,47,0.3)] hover:shadow-[0_6px_20px_rgba(184,142,47,0.4)] focus:outline-none focus:ring-2 focus:ring-[#B88E2F] focus:ring-offset-2 transform hover:-translate-y-0.5">
                Log In
            </button>
        </form>

        <!-- Footer Section -->
        <div class="mt-16 text-center">
            <p class="text-[12px] text-[#B3B3B3]">@2025 Furniro Admin Panel</p>
        </div>
    </div>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    
    const urlParams = new URLSearchParams(window.location.search);
    const successMsg = urlParams.get('success');

    if (successMsg) {
        Swal.fire({
            icon: 'success',
            title: 'Success!',
            text: successMsg,
            confirmButtonColor: '#B88E2F', 
            timer: 1000
        });
    }
</script>
</body>
</html>
