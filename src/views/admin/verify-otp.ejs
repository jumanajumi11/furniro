<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Furniro - Admin Verify OTP</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background-color: #FFFFFF;
        }
        /* Custom scrollbar */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #f1f1f1; }
        ::-webkit-scrollbar-thumb { background: #B88E2F; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #a37d28; }
    </style>
</head>
<body class="min-h-screen flex flex-col items-center justify-center bg-white p-4">

    <!-- Admin Verify OTP Card -->
    <div class="w-full max-w-[500px] bg-white rounded-[24px] shadow-[0_8px_40px_rgba(0,0,0,0.08)] border border-gray-100 px-10 py-12 flex flex-col relative">
        
        <!-- Header Section -->
        <div class="flex flex-col items-center mb-8">
            <div class="flex items-center gap-3 mb-4">
                <img src="https://res.cloudinary.com/dp9odkfmd/image/upload/v1777118568/Meubel_House_Logos-05_uklcwh.png" alt="Furniro Logo" class="h-10 w-10 object-contain">
                <span class="text-[32px] font-bold text-black tracking-tight">Furniro</span>
            </div>
            <h1 class="text-[26px] font-bold text-black mb-3">Verify OTP</h1>
            <p class="text-[14px] text-[#A3A3A3] text-center mb-1">Enter the 6-digit OTP sent to your email</p>
            <p class="text-[15px] font-medium text-black text-center">
                <%= typeof email !== 'undefined' ? email : 'Admin@Furniro.com' %>
            </p>
        </div>

        <!-- Form Section -->
        <form id="otpForm" action="/admin/verify-otp" method="POST" class="w-full flex flex-col gap-6">
            
            <!-- Dynamic Error/Success Messages Placeholder -->
            <% if (typeof error !== 'undefined' && error) { %>
                <div class="bg-red-50 text-red-500 text-sm px-4 py-3 rounded-full border border-red-100 text-center font-medium animate-pulse">
                    <%= error %>
                </div>
            <% } %>
            
            <% if (typeof success !== 'undefined' && success) { %>
                <div class="bg-green-50 text-green-600 text-sm px-4 py-3 rounded-full border border-green-100 text-center font-medium animate-pulse">
                    <%= success %>
                </div>
            <% } %>

            <!-- Verification Code Field -->
            <div class="flex flex-col gap-2">
                <div class="flex justify-between items-center ml-2 mr-2">
                    <label class="text-[14px] font-medium text-[#333333]">Verification Code</label>
                    
                 <span id="timer" class="text-[14px] font-medium text-[#B88E2F]">Starting timer...</span>
                </div>
                <!-- Using type="text" but patterned to look like a code input. You could also use 6 separate boxes, but the design shows one pill input. -->
                <input type="text" name="otp" placeholder="000000" maxlength="6" pattern="\d{6}" required
                    class="w-full h-[54px] px-6 bg-[#EBEBEB] rounded-full text-[18px] tracking-[0.5em] text-center text-gray-800 placeholder-[#B0B0B0] shadow-inner focus:outline-none focus:ring-2 focus:ring-[#B88E2F] focus:bg-white transition-all border border-transparent focus:border-[#B88E2F]"
                    oninput="this.value = this.value.replace(/[^0-9]/g, '')">
            </div>

            <!-- Verify OTP Button -->
            <button id="submitBtn" type="submit" 
                class="w-full h-[56px] mt-2 bg-[#B88E2F] text-white text-[16px] font-semibold rounded-full hover:bg-[#a37d28] transition-all duration-300 shadow-[0_4px_15px_rgba(184,142,47,0.3)] hover:shadow-[0_6px_20px_rgba(184,142,47,0.4)] focus:outline-none focus:ring-2 focus:ring-[#B88E2F] focus:ring-offset-2 transform hover:-translate-y-0.5">
                Verify OTP
            </button>
            
            <!-- Resend OTP Link -->
            <div class="text-center mt-1">
                <p class="text-[14px] text-[#A3A3A3]">
                    Didn't receive the code ?
                    <button id="resendBtn" type="button" onclick="resendOTP()" disabled
                        class="font-semibold text-[#D0D0D0] cursor-not-allowed transition-colors" style="pointer-events:none;">
                        Resend OTP
                    </button>
                </p>
            </div>
        </form>

        <!-- Divider Line -->
        <hr class="my-6 border-gray-100">

        <!-- Back to Login Link -->
        <div class="text-center">
            <a href="/admin/login" class="text-[14px] font-medium text-[#A3A3A3] hover:text-[#B88E2F] transition-colors">
                Back to login
            </a>
        </div>

    </div>

    <!-- Footer Section -->
    <div class="mt-12 text-center relative z-10">
        <p class="text-[12px] text-[#B3B3B3]">@2025 Furniro Admin panel</p>
    </div>

    <script>
    
    const serverExpiry = "<%= (typeof otpExpiry !== 'undefined' && otpExpiry) ? otpExpiry : 0 %>";

    let isExpired = false;
    let countdownInterval = null;

    function setExpiredState() {
        isExpired = true;
        const display = document.getElementById('timer');
        if (display) display.textContent = 'Expired';

        
        const submitBtn = document.getElementById('submitBtn');
        if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.textContent = 'OTP Expired';
            submitBtn.style.cssText = 'background-color:#ccc !important; box-shadow:none !important; transform:none !important; cursor:not-allowed !important;';
        }

        
        const resendBtn = document.getElementById('resendBtn');
        if (resendBtn) {
            resendBtn.disabled = false;
            resendBtn.style.cssText = '';
            resendBtn.className = 'font-semibold text-[#B88E2F] hover:text-[#a37d28] transition-colors cursor-pointer';
        }
    }

    function startTimer(expiryTimestamp) {
        if (countdownInterval) clearInterval(countdownInterval);
        const display = document.getElementById('timer');

        function tick() {
            const remaining = Math.floor((expiryTimestamp - Date.now()) / 1000);
            if (remaining <= 0) {
                clearInterval(countdownInterval);
                setExpiredState();
                return;
            }
            const m = Math.floor(remaining / 60);
            const s = remaining % 60;
            display.textContent = 'Expires in ' +
                (m < 10 ? '0' + m : m) + ':' + (s < 10 ? '0' + s : s);
        }

        tick();
        countdownInterval = setInterval(tick, 1000);
    }

    async function resendOTP() {
        try {
            const response = await fetch('/admin/resend-otp', { method: 'POST' });
            const data = await response.json();

            if (data.success) {
                // Reset expired state
                isExpired = false;

                // Re-enable submit button
                const submitBtn = document.getElementById('submitBtn');
                if (submitBtn) {
                    submitBtn.disabled = false;
                    submitBtn.textContent = 'Verify OTP';
                    submitBtn.style.cssText = '';
                }

                
                const resendBtn = document.getElementById('resendBtn');
                if (resendBtn) {
                    resendBtn.disabled = true;
                    resendBtn.style.cssText = 'pointer-events:none;';
                    resendBtn.className = 'font-semibold text-[#D0D0D0] cursor-not-allowed transition-colors';
                }

                
                startTimer(Date.now() + 60 * 1000);

                Swal.fire({
                    icon: 'success',
                    title: 'OTP Sent!',
                    text: 'A new OTP has been sent to your email.',
                    confirmButtonColor: '#B88E2F',
                    timer: 3000,
                    timerProgressBar: true,
                    showConfirmButton: false
                });
            } else {
                Swal.fire({
                    icon: 'error',
                    title: 'Failed!',
                    text: data.message || 'Failed to resend OTP.',
                    confirmButtonColor: '#B88E2F'
                });
            }
        } catch (err) {
            console.error('Resend error:', err);
            Swal.fire({
                icon: 'error',
                title: 'Server Error',
                text: 'Something went wrong. Please try again.',
                confirmButtonColor: '#B88E2F'
            });
        }
    }

    document.getElementById('otpForm').addEventListener('submit', function (e) {
        if (isExpired) {
            e.preventDefault();
            Swal.fire({
                icon: 'warning',
                title: 'OTP Expired',
                text: 'Your OTP has expired. Please click Resend OTP to get a new one.',
                confirmButtonColor: '#B88E2F'
            });
        }
    });

    window.onload = function () {
        if (serverExpiry && serverExpiry > Date.now()) {
            startTimer(serverExpiry);
        } else if (serverExpiry && serverExpiry <= Date.now()) {
            // Already expired when page loads
            setExpiredState();
        }
    };
    </script>
</body>
</html>
