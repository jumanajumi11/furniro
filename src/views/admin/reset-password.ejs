<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Furniro - Admin Reset Password</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Poppins', sans-serif; background-color: #FFFFFF; }
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #f1f1f1; }
        ::-webkit-scrollbar-thumb { background: #B88E2F; border-radius: 4px; }
    </style>
</head>
<body class="min-h-screen flex flex-col items-center justify-center bg-white p-4 py-10">

    <div class="w-full max-w-[500px] bg-white rounded-[24px] shadow-[0_8px_40px_rgba(0,0,0,0.08)] border border-gray-100 px-10 py-10 flex flex-col relative">
        
        <div class="flex flex-col items-center mb-8">
            <div class="flex items-center gap-3 mb-4">
                <img src="https://res.cloudinary.com/dp9odkfmd/image/upload/v1777118568/Meubel_House_Logos-05_uklcwh.png" alt="Furniro Logo" class="h-10 w-10 object-contain">
                <span class="text-[32px] font-bold text-black tracking-tight">Furniro</span>
            </div>
            <h1 class="text-[26px] font-bold text-black mb-2">Reset Password</h1>
            <p class="text-[14px] text-[#A3A3A3] text-center">Create a new password for your account</p>
        </div>

        <form action="/admin/reset-password" method="POST" class="w-full flex flex-col gap-6">
            
            <% if (typeof error !== 'undefined' && error) { %>
                <div class="bg-red-50 text-red-500 text-sm px-4 py-3 rounded-full border border-red-100 text-center font-medium animate-pulse">
                    <%= error %>
                </div>
            <% } %>

            <div class="flex flex-col gap-2">
                <label class="text-[14px] font-medium text-[#333333] ml-2">New Password</label>
                <div class="relative">
                    <input type="password" name="password" id="newPassword" placeholder="••••••" required
                        class="w-full h-[54px] px-6 pr-12 bg-[#EBEBEB] rounded-full text-[15px] text-gray-800 tracking-widest shadow-inner focus:outline-none focus:ring-2 focus:ring-[#B88E2F] focus:bg-white transition-all border border-transparent focus:border-[#B88E2F]">
                    <button type="button" onclick="togglePassword('newPassword', 'eyeIcon1')" class="absolute right-5 top-1/2 transform -translate-y-1/2 text-gray-500 hover:text-gray-700">
                        <i id="eyeIcon1" class="fas fa-eye-slash"></i>
                    </button>
                </div>
                
                <div class="mt-2 ml-2 mr-2">
                    <div class="w-full h-1.5 bg-gray-200 rounded-full overflow-hidden">
                        <div id="strengthBar" class="w-0 h-full transition-all duration-300"></div>
                    </div>
                    <p id="strengthText" class="text-[12px] font-medium mt-1.5 flex items-center gap-1.5 text-gray-400">
                        <i class="fas fa-exclamation-circle text-[10px]"></i> Password strength: none
                    </p>
                </div>

                <div class="mt-2 bg-[#F6F6F6] rounded-xl p-4 border border-gray-100">
                    <p class="text-[13px] text-gray-700 font-medium mb-3">Password Requirements:</p>
                    <ul class="flex flex-col gap-2.5 text-[12px] text-gray-500 font-medium">
                        <li id="reqLen" class="flex items-center gap-2"><i class="far fa-circle text-[14px]"></i> At least 8 characters</li>
                        <li id="reqNum" class="flex items-center gap-2"><i class="far fa-circle text-[14px]"></i> Contains a Number</li>
                        <li id="reqSpec" class="flex items-center gap-2"><i class="far fa-circle text-[14px]"></i> Contains special character</li>
                    </ul>
                </div>
            </div>

            <div class="flex flex-col gap-2">
                <label class="text-[14px] font-medium text-[#333333] ml-2">Confirm Password</label>
                <div class="relative">
                    <input type="password" name="confirmPassword" id="confirmPassword" placeholder="••••••" required
                        class="w-full h-[54px] px-6 pr-12 bg-[#EBEBEB] rounded-full text-[15px] text-gray-800 tracking-widest shadow-inner focus:outline-none focus:ring-2 focus:ring-[#B88E2F] focus:bg-white transition-all border border-transparent focus:border-[#B88E2F]">
                    <button type="button" onclick="togglePassword('confirmPassword', 'eyeIcon2')" class="absolute right-5 top-1/2 transform -translate-y-1/2 text-gray-500 hover:text-gray-700">
                        <i id="eyeIcon2" class="fas fa-eye-slash"></i>
                    </button>
                </div>
            </div>

            <button type="submit" 
                class="w-full h-[56px] mt-2 bg-[#B88E2F] text-white text-[16px] font-semibold rounded-full hover:bg-[#a37d28] transition-all duration-300 shadow-[0_4px_15px_rgba(184,142,47,0.3)]">
                Reset Password
            </button>
            
            <div class="text-center mt-2">
                <a href="/admin/login" class="text-[14px] font-medium text-[#A3A3A3] hover:text-[#B88E2F] transition-colors flex items-center justify-center gap-2">
                    <i class="fas fa-arrow-left text-[12px]"></i> Back to login
                </a>
            </div>
        </form>

        <hr class="my-8 border-gray-100">
        <div class="text-center">
            <p class="text-[12px] text-[#B3B3B3]">@2025 Furniro Admin panel</p>
        </div>
    </div>

    <script>
        function togglePassword(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('fa-eye-slash', 'fa-eye');
            } else {
                input.type = 'password';
                icon.classList.replace('fa-eye', 'fa-eye-slash');
            }
        }

        const passwordInput = document.getElementById('newPassword');
        passwordInput.addEventListener('input', function(e) {
            const pwd = e.target.value;
            const bar = document.getElementById('strengthBar');
            const text = document.getElementById('strengthText');
            
            let strength = 0;
            if (pwd.length >= 8) { strength++; document.getElementById('reqLen').innerHTML = '<i class="fas fa-check-circle text-green-500"></i> At least 8 characters'; }
            else { document.getElementById('reqLen').innerHTML = '<i class="far fa-circle"></i> At least 8 characters'; }
            
            if (/\d/.test(pwd)) { strength++; document.getElementById('reqNum').innerHTML = '<i class="fas fa-check-circle text-green-500"></i> Contains a Number'; }
            else { document.getElementById('reqNum').innerHTML = '<i class="far fa-circle"></i> Contains a Number'; }
            
            if (/[!@#$%^&*]/.test(pwd)) { strength++; document.getElementById('reqSpec').innerHTML = '<i class="fas fa-check-circle text-green-500"></i> Contains special character'; }
            else { document.getElementById('reqSpec').innerHTML = '<i class="far fa-circle"></i> Contains special character'; }

            if (strength === 0) { bar.className = 'w-0 h-full transition-all'; text.innerText = 'Password strength: none'; text.className = 'text-gray-400 text-[12px] mt-1.5'; }
            if (strength === 1) { bar.className = 'w-1/3 h-full bg-red-500 transition-all'; text.innerText = 'Password strength: weak'; text.className = 'text-red-500 text-[12px] mt-1.5'; }
            if (strength === 2) { bar.className = 'w-2/3 h-full bg-orange-500 transition-all'; text.innerText = 'Password strength: medium'; text.className = 'text-orange-500 text-[12px] mt-1.5'; }
            if (strength === 3) { bar.className = 'w-full h-full bg-green-500 transition-all'; text.innerText = 'Password strength: strong'; text.className = 'text-green-500 text-[12px] mt-1.5'; }
        });
    </script>
</body>
</html>