<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Return Request Details — Furniro Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        * { font-family: 'Plus Jakarta Sans', sans-serif; }
        body { background: #f8f9fb; }
        .card { transition: box-shadow .18s ease; }
        .card:hover { box-shadow: 0 4px 20px -4px rgba(184,142,47,.10); }
    </style>
</head>

<%
    const ordNum = order.orderNumber || ('#' + String(order._id).slice(-8).toUpperCase());
    const user = returnRequest.userId || {};
    const items = returnRequest.items || [];
    
    // Status color mapping
    const STATUS_META = {
        'Requested': { bg: 'bg-orange-50', text: 'text-orange-700', border: 'border-orange-200', dot: 'bg-orange-500' },
        'Approved':  { bg: 'bg-purple-50', text: 'text-purple-700', border: 'border-purple-200', dot: 'bg-purple-500' },
        'Rejected':  { bg: 'bg-rose-50', text: 'text-rose-700', border: 'border-rose-200', dot: 'bg-rose-500' }
    };
    const sm = STATUS_META[returnRequest.status] || STATUS_META['Requested'];
%>

<body class="flex min-h-screen bg-[#f8f9fb]">

<%- include('./adminPartials/adminSidebar.ejs', { activePage: 'orders' }) %>

<div class="flex-1 flex flex-col min-h-screen overflow-hidden">

    <!-- ── TOP NAV BAR ──────────────────────────────────────────────── -->
    <header class="bg-white border-b border-gray-100 px-6 lg:px-8 h-14 flex items-center justify-between flex-shrink-0 z-20">
        <nav class="flex items-center gap-1.5 text-xs font-semibold text-gray-400">
            <a href="/admin/dashboard" class="hover:text-[#B88E2F] transition">Dashboard</a>
            <i class="fas fa-chevron-right text-[9px]"></i>
            <a href="/admin/orders" class="hover:text-[#B88E2F] transition">Orders</a>
            <i class="fas fa-chevron-right text-[9px]"></i>
            <span class="text-gray-700 font-bold">Return Request <%= ordNum %></span>
        </nav>

        <div class="flex items-center gap-3">
            <div class="text-right hidden sm:block">
                <p class="text-[10px] font-black text-[#B88E2F] uppercase tracking-widest leading-none">System Admin</p>
                <p class="text-xs font-bold text-gray-800 mt-0.5">Jumana</p>
            </div>
            <div class="w-9 h-9 rounded-xl bg-[#B88E2F] flex items-center justify-center text-white font-black text-sm shadow">
                JU
            </div>
        </div>
    </header>

    <!-- ── PAGE TITLE SECTION ────────────────────────────────────────── -->
    <div class="bg-white border-b border-gray-100 px-6 lg:px-8 py-5 flex flex-col sm:flex-row sm:items-center justify-between gap-4 flex-shrink-0">
        <div>
            <h1 class="text-2xl font-black text-gray-900 tracking-tight">Return Request for Order <%= ordNum %></h1>
            <p class="text-xs text-gray-400 font-medium mt-1">
                Submitted on
                <%= new Date(returnRequest.createdAt).toLocaleDateString('en-IN', { day:'2-digit', month:'long', year:'numeric', hour: '2-digit', minute: '2-digit' }) %>
            </p>
        </div>

        <div class="flex items-center gap-3 flex-wrap">
            <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-xs font-black uppercase tracking-wider <%= sm.bg %> <%= sm.text %> border <%= sm.border %>">
                <span class="w-1.5 h-1.5 rounded-full <%= sm.dot %> inline-block animate-pulse"></span>
                Return <%= returnRequest.status %>
            </span>
        </div>
    </div>

    <!-- ── MAIN CONTENT AREA ─────────────────────────────────────────── -->
    <div class="flex-1 overflow-y-auto p-6 lg:p-8 space-y-8">
        <div class="max-w-7xl mx-auto flex flex-col lg:flex-row gap-8">
            
            <!-- LEFT COLUMN (65%) -->
            <div class="w-full lg:w-[65%] space-y-8">
                
                <!-- Request Reason Details Card -->
                <div class="bg-white rounded-3xl border border-gray-100 p-6 shadow-sm card">
                    <h2 class="text-base font-extrabold text-gray-900 flex items-center gap-2.5 mb-4">
                        <div class="w-8 h-8 rounded-lg bg-orange-50 flex items-center justify-center text-orange-600">
                            <i class="fas fa-question-circle text-sm"></i>
                        </div>
                        Return Request Reason
                    </h2>
                    <div class="p-4 bg-gray-50 rounded-2xl border border-gray-100">
                        <p class="text-sm font-bold text-gray-800"><%= returnRequest.reason %></p>
                    </div>
                </div>

                <!-- Products Table -->
                <div class="bg-white rounded-3xl border border-gray-100 overflow-hidden shadow-sm card">
                    <div class="p-6 border-b border-gray-50">
                        <h2 class="text-base font-extrabold text-gray-900 flex items-center gap-2.5">
                            <div class="w-8 h-8 rounded-lg bg-amber-50 flex items-center justify-center text-[#B88E2F]">
                                <i class="fas fa-box text-sm"></i>
                            </div>
                            Items Requested for Return
                        </h2>
                    </div>

                    <div class="overflow-x-auto">
                        <table class="w-full text-left">
                            <thead class="bg-gray-50 text-[10px] font-black text-gray-400 uppercase tracking-wider">
                                <tr>
                                    <th class="px-6 py-4">Product</th>
                                    <th class="px-6 py-4">Variant Info</th>
                                    <th class="px-6 py-4 text-center">Qty</th>
                                    <th class="px-6 py-4 text-right">Price</th>
                                    <th class="px-6 py-4 text-right">Total</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-50">
                                <% items.forEach(item => { %>
                                    <%
                                        let prodName = 'Unavailable Product';
                                        let imgSrc = '/images/placeholder.png';
                                        let size = item.size || '';
                                        let color = item.color || '';

                                        if (item.productId) {
                                            prodName = item.productId.productName;
                                            let imgRaw = item.image || (item.productId.images && item.productId.images.length > 0 ? item.productId.images[0] : null);
                                            if (imgRaw) {
                                                imgSrc = imgRaw.startsWith('http') ? imgRaw : '/upload/products/' + imgRaw;
                                            }
                                            if (!size && !color && item.productId.variants && item.productId.variants.length > 0 && item.variantId) {
                                                const variant = item.productId.variants.id(item.variantId);
                                                if (variant) {
                                                    size = variant.size;
                                                    color = variant.color;
                                                }
                                            }
                                        }
                                    %>
                                    <tr class="hover:bg-gray-50/50 transition-colors">
                                        <td class="px-6 py-4 flex items-center gap-3">
                                            <img src="<%= imgSrc %>" alt="<%= prodName %>" class="w-12 h-12 rounded-xl object-cover border border-gray-100 shadow-sm" onerror="this.src='/images/placeholder.png'">
                                            <p class="font-bold text-gray-900 text-xs truncate max-w-[180px]"><%= prodName %></p>
                                        </td>
                                        <td class="px-6 py-4 text-xs text-gray-500 font-semibold">
                                            <% if (size) { %>
                                                <span class="block">Size: <span class="text-gray-800"><%= size %></span></span>
                                            <% } %>
                                            <% if (color) { %>
                                                <span class="block mt-0.5">Color: <span class="text-gray-800"><%= color %></span></span>
                                            <% } %>
                                            <% if (!size && !color) { %>
                                                <span class="text-gray-400 italic">None</span>
                                            <% } %>
                                        </td>
                                        <td class="px-6 py-4 text-center text-xs font-bold text-gray-700">
                                            <%= item.quantity %>
                                        </td>
                                        <td class="px-6 py-4 text-right text-xs font-bold text-gray-700">
                                            ₹<%= item.price.toLocaleString('en-IN') %>
                                        </td>
                                        <td class="px-6 py-4 text-right text-xs font-extrabold text-[#B88E2F]">
                                            ₹<%= (item.price * item.quantity).toLocaleString('en-IN') %>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- RIGHT SIDEBAR (35%) -->
            <div class="w-full lg:w-[35%] space-y-8">
                
                <!-- Financial Summary -->
                <div class="bg-white rounded-3xl border border-gray-100 p-6 shadow-sm card">
                    <h3 class="text-xs font-black text-gray-400 uppercase tracking-widest mb-4">Original Financial Details</h3>
                    <div class="space-y-3 text-xs">
                        <div class="flex justify-between text-gray-500">
                            <span>Subtotal</span>
                            <span class="font-bold text-gray-700">₹<%= order.subtotal.toLocaleString('en-IN') %></span>
                        </div>
                        <% if (order.couponDiscount > 0) { %>
                            <div class="flex justify-between text-green-600">
                                <span>Coupon Discount</span>
                                <span class="font-bold">-₹<%= order.couponDiscount.toLocaleString('en-IN') %></span>
                            </div>
                        <% } %>
                        <div class="flex justify-between text-gray-500">
                            <span>Tax (GST 18%)</span>
                            <span class="font-bold text-gray-700">₹<%= order.tax.toLocaleString('en-IN') %></span>
                        </div>
                        <div class="flex justify-between text-gray-500">
                            <span>Shipping</span>
                            <span class="font-bold text-gray-700">₹<%= order.shippingCharge.toLocaleString('en-IN') %></span>
                        </div>
                        <div class="border-t border-dashed border-gray-100 my-2"></div>
                        <%
                            const returnSubtotal = returnRequest.items.reduce((sum, item) => sum + (item.price * item.quantity), 0);
                        %>
                        <div class="flex justify-between items-center pt-1">
                            <span class="text-xs font-black text-gray-900 uppercase">Return Subtotal</span>
                            <span class="text-base font-extrabold text-[#B88E2F]">₹<%= returnSubtotal.toLocaleString('en-IN') %></span>
                        </div>
                    </div>
                </div>

                <!-- Payment details -->
                <div class="bg-white rounded-3xl border border-gray-100 p-6 shadow-sm card">
                    <h3 class="text-xs font-black text-gray-400 uppercase tracking-widest mb-4">Payment Method & Status</h3>
                    <div class="space-y-2.5">
                        <p class="font-bold text-gray-900 text-sm flex items-center gap-2">
                            <i class="fas <%= order.paymentMethod === 'Wallet' ? 'fa-wallet text-purple-400' : (order.paymentMethod === 'COD' ? 'fa-hand-holding-usd text-green-400' : 'fa-globe text-blue-400') %>"></i>
                            <%= order.paymentMethod %>
                        </p>
                        <div>
                            <span class="inline-block text-[9px] uppercase font-black px-2.5 py-1 rounded border tracking-wide mt-1
                                <%= order.paymentStatus === 'Paid' ? 'text-green-600 bg-green-50 border-green-200' : 
                                    (order.paymentStatus === 'Refunded' ? 'text-blue-600 bg-blue-50 border-blue-200' : 'text-amber-600 bg-amber-50 border-amber-200') %>">
                                <%= order.paymentStatus %>
                            </span>
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-3xl border border-gray-100 p-6 shadow-sm card">
                    <h3 class="text-xs font-black text-gray-400 uppercase tracking-widest mb-4">Customer Details</h3>
                    <div class="flex items-center gap-3">
                        <% if (user && user.image) { %>
                            <img
                                src="<%= user.image.startsWith('http') || user.image.startsWith('/') ? user.image : '/upload/' + user.image %>"
                                alt="Avatar"
                                class="w-10 h-10 rounded-full object-cover shadow-sm flex-shrink-0"
                                onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                            >
                            <div
                                style="display:none"
                                class="w-10 h-10 rounded-full bg-[#B88E2F] text-white font-bold flex items-center justify-center shadow-sm text-sm uppercase flex-shrink-0"
                            >
                                <%= (user.name || 'C').charAt(0).toUpperCase() %>
                            </div>
                        <% } else { %>
                            <div class="w-10 h-10 rounded-full bg-[#B88E2F] text-white font-bold flex items-center justify-center shadow-sm text-sm uppercase flex-shrink-0">
                                <%= (user.name || 'C').charAt(0).toUpperCase() %>
                            </div>
                        <% } %>
                        <div>
                            <p class="font-bold text-gray-800 text-xs"><%= user.name || 'Guest' %></p>
                            <p class="text-[10px] text-gray-400 font-medium mt-0.5"><%= user.email %></p>
                            <p class="text-[10px] text-gray-400 font-medium mt-0.5">+91 <%= user.phone || 'N/A' %></p>
                        </div>
                    </div>
                </div>

                <!-- Actions card -->
                <div class="bg-white rounded-3xl border border-gray-100 p-6 shadow-sm card">
                    <h3 class="text-xs font-black text-gray-400 uppercase tracking-widest mb-4">Request Action</h3>
                    <% if (returnRequest.status === 'Requested') { %>
                        <div class="space-y-3">
                            <button onclick="approveReturn()" class="w-full py-3 bg-green-600 hover:bg-green-700 text-white font-bold text-xs rounded-xl shadow-md transition-all flex items-center justify-center gap-2 cursor-pointer">
                                <i class="fas fa-check-circle"></i> Approve Return
                            </button>
                            <button onclick="rejectReturn()" class="w-full py-3 bg-red-500 hover:bg-red-600 text-white font-bold text-xs rounded-xl shadow-md transition-all flex items-center justify-center gap-2 cursor-pointer">
                                <i class="fas fa-times-circle"></i> Reject Return
                            </button>
                        </div>
                    <% } else { %>
                        <div class="text-center py-4 bg-gray-50 border border-gray-100 rounded-2xl">
                            <i class="fas <%= returnRequest.status === 'Approved' ? 'fa-check-circle text-green-500' : 'fa-times-circle text-red-500' %> text-2xl mb-2"></i>
                            <p class="text-xs font-bold text-gray-700">Request <%= returnRequest.status %></p>
                            <% if (returnRequest.status === 'Rejected' && returnRequest.rejectionReason) { %>
                                <p class="text-[10px] text-red-500 italic mt-2 px-3">Reason: <%= returnRequest.rejectionReason %></p>
                            <% } %>
                        </div>
                    <% } %>
                </div>

            </div>
        </div>
    </div>
</div>

<script>
    const defaultColor = '#B88E2F';

    // Approve Return function
    function approveReturn() {
        Swal.fire({
            title: 'Approve Return?',
            text: 'This will process a refund (if paid online/wallet) and restore the stock of all returned items. This action cannot be undone.',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#16a34a',
            cancelButtonColor: '#9CA3AF',
            confirmButtonText: 'Yes, Approve Return',
            cancelButtonText: 'Cancel',
            customClass: {
                popup: 'rounded-2xl',
                confirmButton: 'rounded-xl font-bold px-5 py-2.5 text-xs',
                cancelButton: 'rounded-xl font-bold px-5 py-2.5 text-xs'
            }
        }).then(async (result) => {
            if (result.isConfirmed) {
                Swal.fire({
                    title: 'Processing...',
                    allowOutsideClick: false,
                    didOpen: () => Swal.showLoading()
                });

                try {
                    const response = await fetch('/admin/return-requests/<%= returnRequest._id %>/approve', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' }
                    });
                    const data = await response.json();

                    if (data.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Approved!',
                            text: data.message,
                            timer: 2000,
                            showConfirmButton: false,
                            customClass: { popup: 'rounded-2xl' }
                        }).then(() => {
                            window.location.reload();
                        });
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Failed',
                            text: data.message,
                            confirmButtonColor: defaultColor,
                            customClass: { popup: 'rounded-2xl', confirmButton: 'rounded-xl font-bold px-5 py-2.5 text-xs' }
                        });
                    }
                } catch (err) {
                    console.error('Approve Return Request error:', err);
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: 'An unexpected connection error occurred.',
                        confirmButtonColor: defaultColor,
                        customClass: { popup: 'rounded-2xl', confirmButton: 'rounded-xl font-bold px-5 py-2.5 text-xs' }
                    });
                }
            }
        });
    }

    // Reject Return function
    function rejectReturn() {
        Swal.fire({
            title: 'Reject Return Request',
            text: 'Please enter the reason for rejection (mandatory):',
            input: 'textarea',
            inputPlaceholder: 'Type rejection reason here...',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#dc2626',
            cancelButtonColor: '#9CA3AF',
            confirmButtonText: 'Reject Return',
            cancelButtonText: 'Cancel',
            inputValidator: (value) => {
                if (!value || !value.trim()) {
                    return 'You must specify a reason for rejection!';
                }
            },
            customClass: {
                popup: 'rounded-2xl',
                confirmButton: 'rounded-xl font-bold px-5 py-2.5 text-xs',
                cancelButton: 'rounded-xl font-bold px-5 py-2.5 text-xs'
            }
        }).then(async (result) => {
            if (result.isConfirmed) {
                Swal.fire({
                    title: 'Processing...',
                    allowOutsideClick: false,
                    didOpen: () => Swal.showLoading()
                });

                try {
                    const response = await fetch('/admin/return-requests/<%= returnRequest._id %>/reject', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ reason: result.value })
                    });
                    const data = await response.json();

                    if (data.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Rejected',
                            text: data.message,
                            timer: 2000,
                            showConfirmButton: false,
                            customClass: { popup: 'rounded-2xl' }
                        }).then(() => {
                            window.location.reload();
                        });
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Failed',
                            text: data.message,
                            confirmButtonColor: defaultColor,
                            customClass: { popup: 'rounded-2xl', confirmButton: 'rounded-xl font-bold px-5 py-2.5 text-xs' }
                        });
                    }
                } catch (err) {
                    console.error('Reject Return Request error:', err);
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: 'An unexpected connection error occurred.',
                        confirmButtonColor: defaultColor,
                        customClass: { popup: 'rounded-2xl', confirmButton: 'rounded-xl font-bold px-5 py-2.5 text-xs' }
                    });
                }
            }
        });
    }
</script>

</body>
</html>
