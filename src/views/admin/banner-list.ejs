<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Banner Management - Furniro Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <!-- Cropper.js CDN -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js"></script>

    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: #F9FAFB; }
        .cropper-container { width: 100% !important; }
    </style>
</head>
<body class="flex min-h-screen">

<%- include('./adminPartials/adminSidebar.ejs', { activePage: 'banners' }) %>

<main class="flex-1 p-6 lg:p-10 overflow-y-auto max-w-7xl mx-auto w-full">
    
    <!-- Header -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
        <div>
            <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">BANNER MANAGEMENT</h1>
            <p class="text-gray-500 mt-1 text-sm font-medium">Create, edit, and delete advertising banners for Home and Shop pages.</p>
        </div>
        
        <div class="flex items-center gap-3">
            <button onclick="openModal('create')" class="px-6 py-3 bg-[#B88E2F] hover:bg-[#9c7524] text-white font-bold text-sm rounded-2xl flex items-center gap-2 shadow-md shadow-[#B88E2F]/15 transition">
                <i class="fas fa-plus"></i> Create Banner
            </button>
            
            <div class="flex items-center gap-3 bg-white px-4 py-2 rounded-2xl border border-gray-100 shadow-sm">
                <div class="text-right">
                    <p class="text-xs font-black text-[#B88E2F] uppercase tracking-widest">System Admin</p>
                    <p class="text-sm font-bold text-gray-900 leading-none mt-0.5">Jumana</p>
                </div>
                <div class="w-10 h-10 rounded-xl bg-[#B88E2F] flex items-center justify-center text-white font-extrabold text-sm shadow-inner">
                    JU
                </div>
            </div>
        </div>
    </div>

    <!-- Banners Table -->
    <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="overflow-x-auto w-full">
            <table class="w-full text-left min-w-[950px]">
                <thead class="bg-gray-50/75 border-b border-gray-100 sticky top-0 backdrop-blur-md">
                    <tr>
                        <th class="px-6 py-4.5 text-[10px] font-black text-gray-400 uppercase tracking-wider">Banner Preview</th>
                        <th class="px-6 py-4.5 text-[10px] font-black text-gray-400 uppercase tracking-wider">Banner Title</th>
                        <th class="px-6 py-4.5 text-[10px] font-black text-gray-400 uppercase tracking-wider">Page (Home / Shop)</th>
                        <th class="px-6 py-4.5 text-[10px] font-black text-gray-400 uppercase tracking-wider text-center">Status</th>
                        <th class="px-6 py-4.5 text-[10px] font-black text-gray-400 uppercase tracking-wider">Last Updated</th>
                        <th class="px-6 py-4.5 text-[10px] font-black text-gray-400 uppercase tracking-wider text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50" id="banners-table-body">
                    <% if (banners && banners.length > 0) { %>
                        <% banners.forEach(banner => { %>
                            <tr class="hover:bg-gray-50/30 transition-colors" id="row-<%= banner._id %>">
                                <td class="px-6 py-4">
                                    <div class="w-24 h-12 rounded-lg overflow-hidden border border-gray-100 shadow-inner bg-gray-50 flex items-center justify-center">
                                        <% if (banner.imageUrl) { %>
                                            <img src="<%= banner.imageUrl.startsWith('http') ? banner.imageUrl : '/upload/banners/' + banner.imageUrl %>" alt="Banner Preview" class="w-full h-full object-cover">
                                        <% } else { %>
                                            <span class="text-xs text-gray-400 font-semibold italic">No Image</span>
                                        <% } %>
                                    </div>
                                </td>
                                
                                <td class="px-6 py-4 font-bold text-gray-900 text-sm">
                                    <%= banner.title %>
                                </td>
                                
                                <td class="px-6 py-4 text-xs text-gray-600 font-bold uppercase tracking-wider">
                                    <span class="px-2.5 py-1 bg-amber-50 border border-amber-100 rounded-lg text-amber-700">
                                        <%= banner.page %>
                                    </span>
                                </td>
                                
                                <td class="px-6 py-4 text-center">
                                    <% if (banner.status === 'Active') { %>
                                        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full border text-[10px] font-black uppercase tracking-wider shadow-sm bg-green-50 border-green-200 text-green-700">
                                            <span class="w-1.5 h-1.5 rounded-full inline-block bg-green-500"></span>
                                            Active
                                        </span>
                                    <% } else { %>
                                        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full border text-[10px] font-black uppercase tracking-wider shadow-sm bg-gray-50 border-gray-200 text-gray-600">
                                            <span class="w-1.5 h-1.5 rounded-full inline-block bg-gray-400"></span>
                                            Inactive
                                        </span>
                                    <% } %>
                                </td>

                                <td class="px-6 py-4 text-xs text-gray-500 font-semibold">
                                    <%= new Date(banner.updatedAt).toLocaleString('en-IN', { dateStyle: 'medium', timeStyle: 'short' }) %>
                                </td>
                                
                                <td class="px-6 py-4 text-right">
                                    <div class="flex items-center justify-end gap-2">
                                        <!-- Edit Button -->
                                        <button onclick="openModal('edit', '<%= JSON.stringify(banner).replace(/'/g, '\\\'') %>')" 
                                                class="w-9 h-9 flex items-center justify-center text-gray-500 hover:text-[#B88E2F] hover:bg-gray-50 rounded-xl transition border border-transparent hover:border-gray-150"
                                                title="Edit Banner">
                                            <i class="far fa-edit text-sm"></i>
                                        </button>

                                        <!-- Delete Button -->
                                        <button onclick="deleteBanner('<%= banner._id %>')" 
                                                class="w-9 h-9 flex items-center justify-center text-red-500 hover:text-red-700 hover:bg-red-50 rounded-xl transition border border-transparent hover:border-red-100"
                                                title="Delete Banner">
                                            <i class="far fa-trash-alt text-sm"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="6" class="px-6 py-20 text-center bg-gray-50/50">
                                <div class="text-gray-300 text-5xl mb-4"><i class="far fa-images"></i></div>
                                <h3 class="text-lg font-bold text-gray-800 mb-1">No Banners Found</h3>
                                <p class="text-sm text-gray-500 mb-6">Create promotional banners for your shop or home pages.</p>
                                <button onclick="openModal('create')" class="px-6 py-2.5 bg-[#B88E2F] text-white text-xs font-bold rounded-2xl hover:bg-[#9c7524] transition inline-block">
                                    <i class="fas fa-plus mr-1"></i> Add First Banner
                                </button>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

</main>

<!-- Popup Modal for Create / Edit -->
<div id="bannerModal" class="fixed inset-0 bg-black/60 z-50 flex items-center justify-center hidden opacity-0 transition-opacity duration-300">
    <div class="bg-white w-full max-w-2xl rounded-3xl overflow-hidden shadow-2xl mx-4 max-h-[90vh] flex flex-col transform scale-95 transition-transform duration-300" id="modalContainer">
        
        <!-- Modal Header -->
        <div class="px-6 py-5 border-b border-gray-100 flex justify-between items-center bg-gray-50/50">
            <h3 class="font-extrabold text-gray-800 text-lg" id="modalTitle">Create Banner</h3>
            <button onclick="closeModal()" class="w-8 h-8 rounded-xl flex items-center justify-center text-gray-400 hover:text-gray-600 hover:bg-gray-100 transition">
                <i class="fas fa-times"></i>
            </button>
        </div>
        
        <!-- Modal Body -->
        <div class="p-6 overflow-y-auto space-y-6 flex-1">
            <!-- Alert message -->
            <div id="modalAlert" class="hidden p-4 bg-red-50 border border-red-200 text-red-700 rounded-2xl text-xs font-semibold"></div>

            <!-- Banner Title -->
            <div>
                <label class="block text-xs font-black text-gray-400 uppercase tracking-wider mb-2">Banner Title *</label>
                <input type="text" id="bannerTitle" placeholder="Enter banner title" 
                       class="w-full bg-gray-50 border border-gray-200 text-gray-800 text-sm rounded-2xl px-4 py-3 outline-none focus:ring-2 focus:ring-[#B88E2F]/20 focus:border-[#B88E2F] transition-all font-bold">
            </div>

            <!-- Page Selector & Status Toggle -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Page Selector -->
                <div>
                    <label class="block text-xs font-black text-gray-400 uppercase tracking-wider mb-2">Page Location *</label>
                    <select id="bannerPage" onchange="updateAspectCropRatio()"
                            class="w-full bg-gray-50 border border-gray-200 text-gray-700 text-sm rounded-2xl px-4 py-3 outline-none focus:ring-2 focus:ring-[#B88E2F]/20 focus:border-[#B88E2F] transition-all cursor-pointer font-bold">
                        <option value="home">Home Page</option>
                        <option value="shop">Shop Page</option>
                    </select>
                </div>

                <!-- Status Toggle -->
                <div>
                    <label class="block text-xs font-black text-gray-400 uppercase tracking-wider mb-2">Status *</label>
                    <select id="bannerStatus"
                            class="w-full bg-gray-50 border border-gray-200 text-gray-700 text-sm rounded-2xl px-4 py-3 outline-none focus:ring-2 focus:ring-[#B88E2F]/20 focus:border-[#B88E2F] transition-all cursor-pointer font-bold">
                        <option value="Active">Active</option>
                        <option value="Inactive">Inactive</option>
                    </select>
                </div>
            </div>

            <!-- Image File Upload -->
            <div>
                <label class="block text-xs font-black text-gray-400 uppercase tracking-wider mb-2">Banner Image File *</label>
                <div class="flex items-center gap-3">
                    <label class="px-5 py-3 bg-gray-100 hover:bg-gray-200 text-gray-600 font-bold text-xs rounded-2xl cursor-pointer transition shadow-sm border border-gray-200">
                        Select File
                        <input type="file" id="bannerImage" accept=".jpg,.jpeg,.png,.webp" class="hidden" onchange="handleImageSelect(event)">
                    </label>
                    <button type="button" id="removeImageBtn" onclick="removeImage()" class="hidden px-5 py-3 bg-red-50 hover:bg-red-100 text-red-600 font-bold text-xs rounded-2xl transition border border-red-100 shadow-sm">
                        <i class="far fa-trash-alt mr-1"></i> Remove Image
                    </button>
                    <span id="fileNameLabel" class="text-xs text-gray-400 font-semibold italic">No file chosen</span>
                </div>
                <p id="imageError" class="text-xs text-red-500 font-semibold mt-1 hidden"></p>
                <p class="text-[10px] text-gray-400 font-medium mt-1.5">Only JPG, JPEG, PNG, WEBP. Max size: 5MB.</p>
            </div>

            <!-- Image Cropper area -->
            <div id="cropperWrapper" class="hidden space-y-4">
                <label class="block text-xs font-black text-gray-400 uppercase tracking-wider">Crop Banner Image</label>
                <div class="w-full max-h-[300px] overflow-hidden bg-gray-100 rounded-2xl flex items-center justify-center border border-gray-200">
                    <img id="cropperImage" class="max-w-full max-h-full block">
                </div>
                
                <!-- Cropper Controls -->
                <div class="flex items-center justify-between gap-3">
                    <div class="flex gap-2">
                        <button type="button" id="zoomInBtn" class="px-3.5 py-2 bg-gray-100 hover:bg-gray-200 text-gray-600 rounded-xl text-xs font-bold transition shadow-sm border border-gray-200" title="Zoom In">
                            <i class="fas fa-search-plus"></i>
                        </button>
                        <button type="button" id="zoomOutBtn" class="px-3.5 py-2 bg-gray-100 hover:bg-gray-200 text-gray-600 rounded-xl text-xs font-bold transition shadow-sm border border-gray-200" title="Zoom Out">
                            <i class="fas fa-search-minus"></i>
                        </button>
                    </div>
                    <span class="text-[10px] text-gray-400 font-semibold" id="ratioHint">Zoom and drag to frame your image</span>
                </div>
            </div>
        </div>

        <!-- Modal Footer -->
        <div class="px-6 py-4 bg-gray-50 border-t border-gray-100 flex justify-end gap-3">
            <button onclick="closeModal()" class="px-5 py-3 bg-white border border-gray-200 text-gray-600 font-bold text-xs rounded-2xl hover:bg-gray-50 transition shadow-sm">
                Cancel
            </button>
            <button id="saveBannerBtn" onclick="saveBanner()" class="px-6 py-3 bg-[#B88E2F] hover:bg-[#9c7524] text-white font-bold text-xs rounded-2xl shadow transition flex items-center gap-1.5 shadow-[#B88E2F]/15">
                <i class="fas fa-save"></i> Save Banner
            </button>
        </div>
    </div>
</div>

<script>
    let modalMode = 'create'; // 'create' or 'edit'
    let editingBannerId = null;
    let cropper = null;
    let isImageRemoved = false;

    function openModal(mode, bannerJson) {
        modalMode = mode;
        isImageRemoved = false;
        
        // Reset fields
        document.getElementById('bannerTitle').value = '';
        document.getElementById('bannerPage').value = 'home';
        document.getElementById('bannerStatus').value = 'Active';
        document.getElementById('bannerImage').value = '';
        document.getElementById('fileNameLabel').textContent = 'No file chosen';
        document.getElementById('modalAlert').classList.add('hidden');
        document.getElementById('cropperWrapper').classList.add('hidden');
        document.getElementById('removeImageBtn').classList.add('hidden');
        
        // Clear errors
        document.getElementById('imageError').classList.add('hidden');
        document.getElementById('imageError').textContent = '';

        if (cropper) {
            cropper.destroy();
            cropper = null;
        }

        if (mode === 'edit') {
            const banner = JSON.parse(bannerJson);
            editingBannerId = banner._id;
            
            document.getElementById('modalTitle').textContent = 'Edit Banner';
            document.getElementById('bannerTitle').value = banner.title;
            document.getElementById('bannerPage').value = banner.page;
            document.getElementById('bannerStatus').value = banner.status;

            // Show existing image instantly if it exists
            if (banner.imageUrl) {
                const cropperImage = document.getElementById('cropperImage');
                cropperImage.src = banner.imageUrl.startsWith('http') ? banner.imageUrl : `/upload/banners/${banner.imageUrl}`;
                document.getElementById('cropperWrapper').classList.remove('hidden');
                document.getElementById('removeImageBtn').classList.remove('hidden');
                document.getElementById('fileNameLabel').textContent = 'Keep existing image';
            } else {
                document.getElementById('fileNameLabel').textContent = 'No file chosen';
            }
        } else {
            editingBannerId = null;
            document.getElementById('modalTitle').textContent = 'Create Banner';
        }

        // Show Modal
        const modal = document.getElementById('bannerModal');
        const container = document.getElementById('modalContainer');
        modal.classList.remove('hidden');
        setTimeout(() => {
            modal.classList.remove('opacity-0');
            container.classList.remove('scale-95');
        }, 10);
    }

    function closeModal() {
        const modal = document.getElementById('bannerModal');
        const container = document.getElementById('modalContainer');
        modal.classList.add('opacity-0');
        container.classList.add('scale-95');
        setTimeout(() => {
            modal.classList.add('hidden');
            if (cropper) {
                cropper.destroy();
                cropper = null;
            }
        }, 300);
    }

    function showAlert(msg) {
        const alertDiv = document.getElementById('modalAlert');
        alertDiv.textContent = msg;
        alertDiv.classList.remove('hidden');
    }

    function removeImage() {
        isImageRemoved = true;
        document.getElementById('bannerImage').value = '';
        document.getElementById('fileNameLabel').textContent = 'No file chosen';
        document.getElementById('cropperWrapper').classList.add('hidden');
        document.getElementById('removeImageBtn').classList.add('hidden');
        
        const cropperImage = document.getElementById('cropperImage');
        cropperImage.src = '';
        
        if (cropper) {
            cropper.destroy();
            cropper = null;
        }

        // Display strict message immediately
        if (modalMode === 'edit') {
            document.getElementById('imageError').textContent = 'Please upload a banner image.';
        } else {
            document.getElementById('imageError').textContent = 'Banner image is required.';
        }
        document.getElementById('imageError').classList.remove('hidden');
    }

    function updateAspectCropRatio() {
        if (!cropper) return;
        
        const page = document.getElementById('bannerPage').value;
        const ratio = page === 'home' ? (16 / 9) : (16 / 5);
        cropper.setAspectRatio(ratio);
        
        document.getElementById('ratioHint').textContent = `Zoom and drag to frame image (${page === 'home' ? '16:9' : '16:5'})`;
    }

    function handleImageSelect(e) {
        const file = e.target.files[0];
        if (!file) return;

        // Validation
        const allowedTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/webp'];
        if (!allowedTypes.includes(file.type)) {
            document.getElementById('imageError').textContent = 'Only JPG, JPEG, PNG, and WEBP files are allowed.';
            document.getElementById('imageError').classList.remove('hidden');
            e.target.value = '';
            return;
        }

        const maxSize = 5 * 1024 * 1024;
        if (file.size > maxSize) {
            document.getElementById('imageError').textContent = 'Maximum image size is 5MB.';
            document.getElementById('imageError').classList.remove('hidden');
            e.target.value = '';
            return;
        }

        // Clear error if valid
        document.getElementById('imageError').classList.add('hidden');
        document.getElementById('imageError').textContent = '';
        document.getElementById('modalAlert').classList.add('hidden');
        document.getElementById('fileNameLabel').textContent = file.name;
        document.getElementById('removeImageBtn').classList.remove('hidden');
        isImageRemoved = false;

        // Initialize Cropper
        const reader = new FileReader();
        reader.onload = function(event) {
            const cropperImage = document.getElementById('cropperImage');
            cropperImage.src = event.target.result;
            
            document.getElementById('cropperWrapper').classList.remove('hidden');

            if (cropper) {
                cropper.destroy();
            }

            const page = document.getElementById('bannerPage').value;
            const ratio = page === 'home' ? (16 / 9) : (16 / 5);

            cropper = new Cropper(cropperImage, {
                aspectRatio: ratio,
                viewMode: 1,
                dragMode: 'move',
                autoCropArea: 1,
                guides: true,
                center: true,
                highlight: false,
                cropBoxResizable: true,
                cropBoxMovable: true,
            });

            document.getElementById('zoomInBtn').onclick = () => cropper.zoom(0.1);
            document.getElementById('zoomOutBtn').onclick = () => cropper.zoom(-0.1);
            updateAspectCropRatio();
        };
        reader.readAsDataURL(file);
    }

    function saveBanner() {
        const title = document.getElementById('bannerTitle').value.trim();
        const page = document.getElementById('bannerPage').value;
        const status = document.getElementById('bannerStatus').value;

        // Clear previous error styles
        document.getElementById('imageError').classList.add('hidden');

        if (!title) {
            showAlert('Banner title is required.');
            return;
        }

        if (!page) {
            showAlert('Banner page is required.');
            return;
        }

        // Validate image presence
        if (modalMode === 'create' && !cropper) {
            document.getElementById('imageError').textContent = 'Banner image is required.';
            document.getElementById('imageError').classList.remove('hidden');
            return;
        }

        if (modalMode === 'edit' && isImageRemoved && !cropper) {
            document.getElementById('imageError').textContent = 'Please upload a banner image.';
            document.getElementById('imageError').classList.remove('hidden');
            return;
        }

        const saveBtn = document.getElementById('saveBannerBtn');
        saveBtn.disabled = true;
        saveBtn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1"></i> Saving...';

        const submitForm = async (imageBlob) => {
            const formData = new FormData();
            formData.append('title', title);
            formData.append('page', page);
            formData.append('status', status);
            formData.append('imageRemoved', isImageRemoved ? 'true' : 'false');
            
            if (imageBlob) {
                formData.append('bannerImage', imageBlob, 'banner.jpg');
            }

            const url = modalMode === 'create' ? '/admin/banners' : `/admin/banners/${editingBannerId}`;
            const method = modalMode === 'create' ? 'POST' : 'PUT';

            try {
                const res = await fetch(url, {
                    method: method,
                    body: formData
                });
                const data = await res.json();
                if (data.success) {
                    closeModal();
                    Swal.fire({
                        icon: 'success',
                        title: 'Saved Successfully',
                        text: data.message,
                        confirmButtonColor: '#B88E2F'
                    }).then(() => {
                        window.location.reload();
                    });
                } else {
                    showAlert(data.message || 'Failed to save banner.');
                }
            } catch (err) {
                console.error(err);
                showAlert('Error occurred while communicating with the server.');
            } finally {
                saveBtn.disabled = false;
                saveBtn.innerHTML = '<i class="fas fa-save mr-1"></i> Save Banner';
            }
        };

        if (cropper) {
            cropper.getCroppedCanvas({
                imageSmoothingEnabled: true,
                imageSmoothingQuality: 'high'
            }).toBlob((blob) => {
                submitForm(blob);
            }, 'image/jpeg', 0.9);
        } else {
            submitForm(null);
        }
    }

    async function deleteBanner(id) {
        const result = await Swal.fire({
            title: 'Are you sure?',
            text: "This action will permanently delete this banner.",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#B88E2F',
            confirmButtonText: 'Yes, delete it!'
        });

        if (result.isConfirmed) {
            try {
                const res = await fetch(`/admin/banners/${id}`, {
                    method: 'DELETE'
                });
                const data = await res.json();
                if (data.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Deleted!',
                        text: data.message,
                        confirmButtonColor: '#B88E2F'
                    }).then(() => {
                        window.location.reload();
                    });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: data.message,
                        confirmButtonColor: '#B88E2F'
                    });
                }
            } catch (err) {
                console.error(err);
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'An error occurred during deletion.',
                    confirmButtonColor: '#B88E2F'
                });
            }
        }
    }
</script>

</body>
</html>
